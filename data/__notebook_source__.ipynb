# ════════════════════════════════════════════════════════════════════
# LOG DONUSUMLERI
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. Carpik dagilimlari log uzayina cevirmek
#   2. Eksik degerleri 0 ile doldurmak (yokluk = sifir mantigi)
#   3. Donusum oncesi/sonrasi karsilastirma
# ════════════════════════════════════════════════════════════════════

# ── Eksik degerleri 0 ile doldur (sayisal sutunlar) ────────────────
sayisal_sutunlar_log = ['Revenue', 'Copies sold', 'Wishlists', 
                         'Review count', 'Followers']

for col in sayisal_sutunlar_log:
    df_clean[col] = df_clean[col].fillna(0)

# ── Log donusumleri uygula ─────────────────────────────────────────
df_clean['log_revenue'] = np.log1p(df_clean['Revenue'])
df_clean['log_copies'] = np.log1p(df_clean['Copies sold'])
df_clean['log_wishlists'] = np.log1p(df_clean['Wishlists'])
df_clean['log_review_count'] = np.log1p(df_clean['Review count'])
df_clean['log_followers'] = np.log1p(df_clean['Followers'])

# ── Karsilastirma tablosu ──────────────────────────────────────────
print("=" * 90)
print("LOG DONUSUMU SONUCLARI")
print("=" * 90)

print(f"\n{'Sutun':<20} {'Ham Median':>15} {'Ham Max':>20} {'Log Median':>12} {'Log Max':>10} {'Skewness Iyilesme':>18}")
print("-" * 100)

donusumler = {
    'Revenue': 'log_revenue',
    'Copies sold': 'log_copies',
    'Wishlists': 'log_wishlists',
    'Review count': 'log_review_count',
    'Followers': 'log_followers'
}

for ham, log in donusumler.items():
    h_med = df_clean[ham].median()
    h_max = df_clean[ham].max()
    l_med = df_clean[log].median()
    l_max = df_clean[log].max()
    
    # Skewness karsilastirma
    ham_skew = df_clean[ham].skew()
    log_skew = df_clean[log].skew()
    
    print(f"{ham:<20} {h_med:>15,.0f} {h_max:>20,.0f} {l_med:>12.2f} {l_max:>10.2f} "
          f"{ham_skew:>7.1f} -> {log_skew:>+6.2f}")

# ── Gorselleştirme: Once vs Sonra ─────────────────────────────────
fig, axes = plt.subplots(2, 5, figsize=(20, 8))

for i, (ham, log) in enumerate(donusumler.items()):
    # Ust sira: ham veri (log10 olcekte)
    ham_nonzero = df_clean[df_clean[ham] > 0][ham]
    axes[0, i].hist(np.log10(ham_nonzero), bins=40, color='#C73E1D', 
                     edgecolor='black', alpha=0.7)
    axes[0, i].set_title(f'{ham}\n(Ham, log10 olcek)', fontweight='bold', fontsize=10)
    axes[0, i].set_ylabel('Frekans')
    axes[0, i].grid(alpha=0.3)
    
    # Alt sira: log1p donusumlu veri
    axes[1, i].hist(df_clean[log], bins=40, color='#2E86AB', 
                     edgecolor='black', alpha=0.7)
    axes[1, i].set_title(f'{log}\n(log1p donusumlu)', fontweight='bold', fontsize=10)
    axes[1, i].set_ylabel('Frekans')
    axes[1, i].grid(alpha=0.3)

plt.suptitle('Log Donusumu: Once vs Sonra', fontsize=14, fontweight='bold', y=1.00)
plt.tight_layout()
plt.savefig(CIKTI_KLASORU + 'eda_06_log_donusumu.png', dpi=100, bbox_inches='tight')
plt.show()

print(f"\nGrafik kaydedildi: {CIKTI_KLASORU}eda_06_log_donusumu.png")

# ── Skewness karsilastirma ozeti ───────────────────────────────────
print("\n" + "=" * 70)
print("SKEWNESS IYILESMESI - OZET")
print("=" * 70)
print("\nLog donusumu CARPIKLIGI GIDERMEKTE NE KADAR BASARILI?")
print()
print(f"{'Sutun':<20} {'Ham Skewness':>15} {'Log Skewness':>15} {'Iyilesme':>10}")
print("-" * 65)
for ham, log in donusumler.items():
    h_skew = df_clean[ham].skew()
    l_skew = df_clean[log].skew()
    iyilesme = abs(h_skew) - abs(l_skew)
    print(f"{ham:<20} {h_skew:>14.1f}  {l_skew:>+14.2f}  {iyilesme:>+9.1f}")

print(f"\n✓ Tum log donusumleri tamamlandi.")
print(f"✓ df_clean uzerinde 5 yeni sutun olusturuldu.")
print(f"\nFinal df_clean boyutu: {df_clean.shape}")








# ════════════════════════════════════════════════════════════════════
# OUTLIER YONETIMI VE EKSIK VERI IMPUTATION
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. price_usd icin 99. percentile clipping
#   2. Review Score icin median imputation
#   3. Sonuclari raporlamak
# ════════════════════════════════════════════════════════════════════

print("=" * 70)
print("OUTLIER YONETIMI: PRICE 99. PERCENTILE CLIPPING")
print("=" * 70)

# ── 1) PRICE 99. PERCENTILE CLIP ──────────────────────────────────
price_99 = df_clean['price_usd'].quantile(0.99)
oyun_99_uzeri = (df_clean['price_usd'] > price_99).sum()

print(f"\n99. percentile fiyat: ${price_99:.2f}")
print(f"Bu degerin uzerindeki oyun sayisi: {oyun_99_uzeri:,}")
print(f"Oran: {oyun_99_uzeri/len(df_clean)*100:.2f}%")

# Clip uygula
df_clean['price_usd_clipped'] = df_clean['price_usd'].clip(upper=price_99)

print(f"\nClip ONCESI price_usd:")
print(f"  Max:    ${df_clean['price_usd'].max():,.2f}")
print(f"  Mean:   ${df_clean['price_usd'].mean():,.2f}")
print(f"  Std:    ${df_clean['price_usd'].std():,.2f}")

print(f"\nClip SONRASI price_usd_clipped:")
print(f"  Max:    ${df_clean['price_usd_clipped'].max():,.2f}")
print(f"  Mean:   ${df_clean['price_usd_clipped'].mean():,.2f}")
print(f"  Std:    ${df_clean['price_usd_clipped'].std():,.2f}")

# ── 2) REVIEW SCORE EKSIK VERI IMPUTATION ─────────────────────────
print("\n" + "=" * 70)
print("EKSIK VERI IMPUTATION: REVIEW SCORE")
print("=" * 70)

review_nan_count = df_clean['Review Score'].isna().sum()
review_median = df_clean['Review Score'].median()

print(f"\nReview Score eksik veri:")
print(f"  Eksik sayisi:  {review_nan_count:,}")
print(f"  Eksik yuzdesi: {review_nan_count/len(df_clean)*100:.1f}%")
print(f"  Median deger:  {review_median:.1f}")

# Imputation: median ile doldur
df_clean['Review Score'] = df_clean['Review Score'].fillna(review_median)

print(f"\nImputation sonrasi:")
print(f"  Eksik sayisi:  {df_clean['Review Score'].isna().sum()}")
print(f"  Yeni median:   {df_clean['Review Score'].median():.1f}")

