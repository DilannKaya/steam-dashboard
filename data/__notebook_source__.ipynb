# GENRE (TUR) DAGILIMI ANALIZI
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. Genres sutunundan tum benzersiz genre'lari cikarmak
#   2. Her genre'in frekansini hesaplamak
#   3. Top 15 genre'i gorselleştirmek
#   4. Segmentasyon stratejisi icin esik degerlerini belirlemek
# ════════════════════════════════════════════════════════════════════

# ── Genre string'lerini parse et ───────────────────────────────────
def parse_genres(s):
    """Python liste formatindaki string'i parse eder."""
    if pd.isna(s) or s == '':
        return []
    s = str(s).strip()
    # Kose parantez, tirnak isaretlerini kaldir
    s = s.replace('[', '').replace(']', '')
    s = s.replace('"', '').replace("'", '')
    return [x.strip() for x in s.split(',') if x.strip()]

# Tum genre'lari say
all_genres = Counter()
for genres_str in df['Genres'].dropna():
    for g in parse_genres(genres_str):
        all_genres[g] += 1

# DataFrame'e cevir
genre_df = pd.DataFrame({
    'Genre': list(all_genres.keys()),
    'Oyun_Sayisi': list(all_genres.values())
}).sort_values('Oyun_Sayisi', ascending=False).reset_index(drop=True)

# Yuzde hesapla
toplam_oyun = len(df)
genre_df['Yuzde'] = (genre_df['Oyun_Sayisi'] / toplam_oyun) * 100

