    print(f"   {'-'*3} {'-'*35} {'-'*10} {'-'*6} {'-'*7} {'-'*14}")
    for i, b in enumerate(rapor['benzer_oyunlar'], 1):
        rev_str = f"${b['revenue_2025_usd']:>12,.0f}"
        print(f"   {i:<3} {b['adi'][:33]:<35} {b['genre'][:8]:<10} "
              f"{b['similarity_adaptif']:>6.3f} {b['mesafe']:>7.2f} {rev_str}")
    print(f"   * Sim: 5 oyun arasinda goreceli yakinlik (1.0 = en yakin)")
    
    h = rapor['hybrid_tahmin']
    print(f"\n[HYBRID STACKING TAHMINI]")
