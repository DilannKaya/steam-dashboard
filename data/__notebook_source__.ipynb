    ort_wishlist=('Wishlists', 'mean'),
    ort_review_score=('Review Score', 'mean'),
    ort_price=('price_usd', 'mean')
).round(2)

# Sirali (toplam revenue'ye gore)
genre_profil = genre_profil.sort_values('toplam_revenue', ascending=False)

print(f"\n{'Genre':<22} {'Oyun':>8} {'Ort.Rev':>12} {'Med.Rev':>10} {'Toplam Rev':>15} {'Wishlist':>10} {'Review':>8} {'Fiyat':>8}")
