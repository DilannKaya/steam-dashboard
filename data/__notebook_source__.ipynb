#   3. Cluster'lari profillemek
# ════════════════════════════════════════════════════════════════════

# ── KMeans icin ozellikler ────────────────────────────────────────
kmeans_ozellikler = [
    'log_revenue',
    'log_wishlists',
    'log_copies',
    'log_followers',
    'log_review_count',
    'Review Score',
