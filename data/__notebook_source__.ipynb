# ANA FONKSIYON: SENARYO A
# ════════════════════════════════════════════════════════════════

def senaryo_a(steam_id, K=5):
    """Mevcut bir oyun icin tam karar destek raporu uretir."""
    
    if steam_id not in df_clean.index:
        raise ValueError(f"Steam ID {steam_id} veri setinde yok.")
    
    oyun_satiri = df_clean.loc[steam_id]
    oyun_index_global = df_clean.index.get_loc(steam_id)
    
    def safe_get(row, kolon_adaylari, default=None):
        for kolon in kolon_adaylari:
            if kolon in row.index:
                return row[kolon]
        return default
    
    oyun_adi = safe_get(oyun_satiri, ['Name', 'name', 'title', 'Title'], 'Bilinmiyor')
    primary_genre = safe_get(oyun_satiri, ['primary_genre', 'Primary Genre'], 'Bilinmiyor')
    cluster_id = int(safe_get(oyun_satiri, ['kmeans_cluster', 'cluster'], -1))
    
    gercek_2025_log = float(safe_get(oyun_satiri, ['log_revenue', 'log_Revenue'], np.nan))
    gercek_2025_usd = float(np.expm1(gercek_2025_log)) if not np.isnan(gercek_2025_log) else np.nan
    
    # ── ADIM 2: Benzer 5 oyun ─────────────────────────────────────
    oyun_vector = X_zscore[oyun_index_global].reshape(1, -1)
    
    if oyun_index_global in train_idx:
        mesafeler_raw, komsu_local_idx = knn_best.kneighbors(oyun_vector, n_neighbors=K+1)
        komsu_local_idx = komsu_local_idx[0][1:]
        mesafeler_raw = mesafeler_raw[0][1:]
    else:
        mesafeler_raw, komsu_local_idx = knn_best.kneighbors(oyun_vector, n_neighbors=K)
        komsu_local_idx = komsu_local_idx[0]
        mesafeler_raw = mesafeler_raw[0]
    
    komsu_global_idx = train_idx[komsu_local_idx]
    
    # YAMA 2: Adaptif similarity normalizasyon (5 oyun arasi)
    mesafe_min = float(mesafeler_raw.min())
    mesafe_max = float(mesafeler_raw.max())
    mesafe_range = mesafe_max - mesafe_min if mesafe_max > mesafe_min else 1.0
    
    benzer_oyunlar = []
    for i, g_idx in enumerate(komsu_global_idx):
        komsu = df_clean.iloc[g_idx]
        komsu_steam_id = int(df_clean.index[g_idx])
        mesafe = float(mesafeler_raw[i])
        
        # 5 oyun arasi göreceli yakinlik (1.0 = en yakin, 0.0 = en uzak)
        similarity_adaptif = 1.0 - (mesafe - mesafe_min) / mesafe_range
        # Mutlak referans (113K oyun uzayinda)
        similarity_mutlak = max(0.0, 1.0 - mesafe / 30.0)
        
        komsu_log_rev = float(safe_get(komsu, ['log_revenue', 'log_Revenue'], 0))
        komsu_usd = float(np.expm1(komsu_log_rev))
        
        benzer_oyunlar.append({
            'steam_id': komsu_steam_id,
            'adi': str(safe_get(komsu, ['Name', 'name', 'title'], 'Bilinmiyor'))[:50],
            'genre': str(safe_get(komsu, ['primary_genre', 'Primary Genre'], '?')),
            'similarity_adaptif': round(similarity_adaptif, 3),
            'similarity_mutlak': round(similarity_mutlak, 3),
            'mesafe': round(mesafe, 2),
            'revenue_2025_usd': komsu_usd
        })
    
    # ── ADIM 3: Hybrid Stacking ────────────────────────────────────
    y_knn_log = float(knn_best.predict(oyun_vector)[0])
    y_cb_log = content_based_tahmin(oyun_index_global, K=K)
    y_hat_hybrid_log = W_KNN * y_knn_log + W_CB * y_cb_log + B_HYBRID
    
    # ── ADIM 4: Log -> USD ────────────────────────────────────────
    revenue_baz_usd = float(np.expm1(y_hat_hybrid_log))
    
    # ── YAMA 1: Finansal körlük uyarisi (TEK $ SEMBOLU) ──────────
    finansal_korluk_uyarisi = None
    if not np.isnan(gercek_2025_usd) and gercek_2025_usd > 0:
        oran = revenue_baz_usd / gercek_2025_usd
        if oran < 0.3:
            finansal_korluk_uyarisi = (
                f"⚠️ FINANSAL KORLUK TESPIT EDILDI: Hybrid tahmin "
                f"(${revenue_baz_usd:,.0f}) gercek 2025 (${gercek_2025_usd:,.0f}) "
                f"degerinin sadece %{oran*100:.1f}'i. Bu, Bolum 6.7'de gozlemlenen "
                f"%15.3 ortalama finansal korluk yanliliginin somut bir ornegidir. "
                f"Oyun outlier kategorisinde — Hybrid alt-tahmin ediyor."
            )
        elif oran > 3.0:
            finansal_korluk_uyarisi = (
                f"⚠️ ANORMAL UST-TAHMIN: Hybrid tahmin (${revenue_baz_usd:,.0f}) "
                f"gercek (${gercek_2025_usd:,.0f}) degerinin %{oran*100:.0f}'i. Dikkat."
            )
    
    # ── ADIM 5: Cluster CAGR + Fallback ───────────────────────────
    fallback_kullanildi = False
    fallback_sebep = None
    
    if cluster_id in cluster_cagr_dict:
        cagr_bilgi = cluster_cagr_dict[cluster_id]
        cagr_kaynagi = f'Cluster_{cluster_id}'
    elif primary_genre in genre_cagr_dict:
        cagr_bilgi = genre_cagr_dict[primary_genre]
        cagr_kaynagi = f'{primary_genre} (genre fallback)'
        fallback_kullanildi = True
        fallback_sebep = f'Cluster_{cluster_id} Bolum 7.6 filtreledi'
    else:
        cagr_bilgi = {'cagr': FALLBACK_CAGR, 'mape': 50.0, 'algo': 'FALLBACK'}
        cagr_kaynagi = 'Toplam pazar (genel fallback)'
        fallback_kullanildi = True
        fallback_sebep = 'Hem cluster hem genre filtreledi'
    
    cluster_cagr = cagr_bilgi['cagr']
    cluster_mape = cagr_bilgi['mape']
    cluster_algo = cagr_bilgi['algo']
    
    guven_seviyesi, yatirim_onerisi_kalitatif = lewis_kategorisi(cluster_mape)
    
    # ── ADIM 6-7: 2027 + Worst/Best ───────────────────────────────
    revenue_2027_base = revenue_baz_usd * ((1 + cluster_cagr) ** 2)
    revenue_2027_worst = revenue_2027_base * 0.70
    revenue_2027_best = revenue_2027_base * 1.30
    
    # ── RAPOR ─────────────────────────────────────────────────────
    rapor = {
        'oyun_bilgisi': {
            'steam_id': int(steam_id),
            'oyun_adi': str(oyun_adi),
            'primary_genre': str(primary_genre),
            'kmeans_cluster': cluster_id,
            'gercek_2025_log': round(gercek_2025_log, 4) if not np.isnan(gercek_2025_log) else None,
            'gercek_2025_usd': round(gercek_2025_usd, 2) if not np.isnan(gercek_2025_usd) else None,
            'is_train': bool(oyun_index_global in train_idx)
        },
        'benzer_oyunlar': benzer_oyunlar,
        'hybrid_tahmin': {
            'y_knn_log': round(y_knn_log, 4),
            'y_cb_log': round(y_cb_log, 4),
            'y_hat_hybrid_log': round(y_hat_hybrid_log, 4),
            'revenue_baz_usd': round(revenue_baz_usd, 2),
            'formul': f"{W_KNN:+.4f}*y_knn + {W_CB:+.4f}*y_cb + {B_HYBRID:+.4f}",
            'finansal_korluk_uyarisi': finansal_korluk_uyarisi
        },
        'segment_bilgisi': {
            'cagr_kaynagi': cagr_kaynagi,
            'cluster_cagr_yillik': round(cluster_cagr, 4),
            'cluster_cagr_yuzde': round(cluster_cagr * 100, 2),
            'cluster_mape': round(cluster_mape, 2),
            'cluster_algoritma': cluster_algo,
            'guven_seviyesi': guven_seviyesi,
            'fallback_kullanildi': fallback_kullanildi,
            'fallback_sebep': fallback_sebep
        },
        '2027_projeksiyon_usd': {
            'worst_case': round(revenue_2027_worst, 2),
            'base_case': round(revenue_2027_base, 2),
            'best_case': round(revenue_2027_best, 2),
            'buyume_yuzde': round((revenue_2027_base / revenue_baz_usd - 1) * 100, 2)
            if revenue_baz_usd > 0 else 0.0
        },
        'yatirim_onerisi': yatirim_onerisi_kalitatif
    }
    
    return rapor


