# ════════════════════════════════════════════════════════════════════
# YILLIK STEAM PAZARI BUYUME ANALIZI
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. Her yil icin toplam revenue ve sales hesaplamak
#   2. Yillik buyume oranlarini hesaplamak
#   3. CAGR (Compound Annual Growth Rate) belirlemek
#   4. Pazarin buyume trendini gorselleştirmek
# ════════════════════════════════════════════════════════════════════

yillar = list(range(2015, 2026))

# Yillik toplam revenue ve sales
yillik_data = []
for yil in yillar:
    rev_col = f'{yil} revenue'
    sales_col = f'{yil} sales'
    
    toplam_rev = df[rev_col].sum() / 1e9  # Milyar dolar
    toplam_sales = df[sales_col].sum() / 1e6  # Milyon kopya
    
    # Veri kapsamı: o yıl için eksik olmayan oyun sayısı
    revenue_kapsam = df[rev_col].notna().sum()
    
    yillik_data.append({
        'Yil': yil,
        'Revenue_B': toplam_rev,
        'Sales_M': toplam_sales,
        'Veri_Kapsami': revenue_kapsam
    })

yillik_df = pd.DataFrame(yillik_data)

# ── Yillik buyume oranlari ────────────────────────────────────────
yillik_df['Revenue_Buyume_%'] = yillik_df['Revenue_B'].pct_change() * 100
yillik_df['Sales_Buyume_%'] = yillik_df['Sales_M'].pct_change() * 100

print("=" * 75)
print("STEAM PAZARI YILLIK BUYUME ANALIZI")
print("=" * 75)
