# ════════════════════════════════════════════════════════════════════
# 5 ZAMAN SERISI ALGORITMASI KARSILASTIRMASI (PROFESYONEL VERSIYON)
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. Linear, ARIMA (AIC-optimize), Holt-Winters, Prophet, LightGBM
#   2. Her algoritmayi her ANLAMLI genre/cluster icin calistir
#   3. Test setinde MAPE, RMSE, MAE hesapla
#   4. Her segment icin en iyi modeli sec (Best-of-Best)
#   5. 2027 toplam pazar projeksiyonu uret (guvenilir vs tum)
#
# Metodolojik notlar (Bolum 7 girisinde aciklandi):
# - Yillik veride mevsimsellik yoktur → Holt-Winters seasonal=None,
#   Prophet yearly_seasonality=False (sadece trend bileseni aktif)
# - LightGBM n_lag=2 sinirli train (9 yil) ile dengeli secim
# - ARIMA(p,d,q) AIC grid search ile segment-spesifik optimize edilir
# - Negatif forecast'lar clip ile 0'a sabitlenir (revenue >= 0 kisiti)
# - Anlamsiz segmentler (max < $10M veya test ort < $10M) atlanir
# ════════════════════════════════════════════════════════════════════

import warnings
warnings.filterwarnings('ignore')

# Prophet ve LightGBM availability check
try:
    from prophet import Prophet
    PROPHET_AVAILABLE = True
except ImportError:
    PROPHET_AVAILABLE = False

try:
    import lightgbm as lgb
    LGBM_AVAILABLE = True
except ImportError:
    LGBM_AVAILABLE = False

# Prophet'in INFO loglarini bastir
import logging
logging.getLogger('cmdstanpy').setLevel(logging.WARNING)
logging.getLogger('prophet').setLevel(logging.WARNING)

# ARIMA grid search icin
from itertools import product

print("=" * 70)
print("5 ZAMAN SERISI ALGORITMASI KARSILASTIRMASI")
print("=" * 70)
print(f"\nKullanilabilir algoritmalar:")
print(f"  - Linear Regression:  ✓")
print(f"  - ARIMA (AIC-grid):   ✓")
print(f"  - Holt-Winters:       ✓")
print(f"  - Prophet:            {'✓' if PROPHET_AVAILABLE else '✗ (yuklu degil)'}")
print(f"  - LightGBM:           {'✓' if LGBM_AVAILABLE else '✗ (yuklu degil)'}")

# ════════════════════════════════════════════════════════════════
# ALGORITMA FONKSIYONLARI
# ════════════════════════════════════════════════════════════════

def algo_linear(train_data, train_yil, test_yil, forecast_yil):
    """
    Linear Regression: y = a*yil + b
    En basit baseline. Yillik trend dominantsa yeterli.
    """
    X_tr = np.array(train_yil).reshape(-1, 1)
    model = LinearRegression()
    model.fit(X_tr, train_data)
    test_pred = model.predict(np.array(test_yil).reshape(-1, 1))
    forecast_pred = model.predict(np.array(forecast_yil).reshape(-1, 1))
    return test_pred, forecast_pred


def algo_prophet(train_data, train_yil, test_yil, forecast_yil):
    """
    Facebook Prophet (Taylor & Letham, 2018).
    Yillik veride mevsimsellik PASIF — yalnizca trend bileseni aktif.
    """
    df_pr = pd.DataFrame({
        'ds': pd.to_datetime([f'{y}-01-01' for y in train_yil]),
        'y': train_data
    })
    # Tum seasonality bilesenleri kapali — yillik veride anlamsiz
    model = Prophet(
        yearly_seasonality=False,   # Yillik veri → anlamsiz
        weekly_seasonality=False,
        daily_seasonality=False,
        interval_width=0.95
    )
    model.fit(df_pr)
    future_yil = test_yil + forecast_yil
    future_df = pd.DataFrame({
        'ds': pd.to_datetime([f'{y}-01-01' for y in future_yil])
    })
    forecast = model.predict(future_df)
    yhat = forecast['yhat'].values
    return yhat[:len(test_yil)], yhat[len(test_yil):]


def algo_arima(train_data, train_yil, test_yil, forecast_yil):
    """
    ARIMA(p,d,q) - AIC grid search ile segment-spesifik optimize.
    Box-Jenkins (1970) metodolojisinin kucuk versiyonu.
    
    Grid: p in [0,1,2], d in [0,1], q in [0,1,2] → 18 model
    En dusuk AIC kazanir. Klasik (1,1,1) hardcoded yerine
    veriden ogrenilen optimal (p,d,q) kullanilir.
    """
    best_aic = np.inf
    best_order = (1, 1, 1)  # Fallback
    
    for p, d, q in product([0, 1, 2], [0, 1], [0, 1, 2]):
        if p == 0 and q == 0:
            continue  # Tum sifir anlamsiz
        try:
            model = ARIMA(train_data, order=(p, d, q))
            fit = model.fit()
            if fit.aic < best_aic:
                best_aic = fit.aic
                best_order = (p, d, q)
        except Exception:
            continue
    
    # En iyi modeli yeniden fit et
    try:
        model = ARIMA(train_data, order=best_order)
        fit = model.fit()
        forecast = fit.forecast(steps=len(test_yil) + len(forecast_yil))
        return (np.array(forecast[:len(test_yil)]), 
                np.array(forecast[len(test_yil):]))
    except Exception:
        # Son care: basit ARIMA(1,1,0)
        model = ARIMA(train_data, order=(1, 1, 0))
        fit = model.fit()
        forecast = fit.forecast(steps=len(test_yil) + len(forecast_yil))
        return (np.array(forecast[:len(test_yil)]), 
                np.array(forecast[len(test_yil):]))


def algo_holtwinters(train_data, train_yil, test_yil, forecast_yil):
    """
    Holt-Winters Exponential Smoothing.
    
    NOT: Triple ES (Level + Trend + Seasonality) yerine bu projede
    Double ES (Holt's Linear Trend) gibi davranir — seasonal=None,
    cunku yillik veride mevsimsellik gozlemlenemez (Bolum 7.3'te aciklandi).
    """
    try:
        model = ExponentialSmoothing(
            train_data, 
            trend='add',       # Aditif trend
            seasonal=None      # Yillik veri → mevsimsellik PASIF
        )
        fit = model.fit()
        forecast = fit.forecast(steps=len(test_yil) + len(forecast_yil))
        return (np.array(forecast[:len(test_yil)]), 
                np.array(forecast[len(test_yil):]))
    except Exception:
        # Fallback: trend de yok, simple exponential smoothing
        model = ExponentialSmoothing(train_data, trend=None, seasonal=None)
        fit = model.fit()
        forecast = fit.forecast(steps=len(test_yil) + len(forecast_yil))
        return (np.array(forecast[:len(test_yil)]), 
                np.array(forecast[len(test_yil):]))


def algo_lightgbm(train_data, train_yil, test_yil, forecast_yil):
    """
    LightGBM - lag feature ile iterative forecast.
    
    n_lag=2: 9 yillik train icin denge. Daha fazla lag sample sayisini
    dusurur (9-3=6 sample → overfit). n_lag=2 ile 7 sample elde edilir.
    """
    n_lag = 2  # 9 yillik train icin sinirli; daha fazla lag overfit riski
    
    if len(train_data) < n_lag + 1:
        # Cok az veri, Linear fallback
        return algo_linear(train_data, train_yil, test_yil, forecast_yil)
    
    # Lag features olustur
    X_list, y_list = [], []
    for i in range(n_lag, len(train_data)):
        X_list.append([train_yil[i]] + list(train_data[i-n_lag:i]))
        y_list.append(train_data[i])
    
    X_tr = np.array(X_list)
    y_tr = np.array(y_list)
    
    model = lgb.LGBMRegressor(
        n_estimators=50,      # Az veri → az tree
        max_depth=3,          # Az veri → sig tree
        learning_rate=0.1,
        verbose=-1,
        random_state=RANDOM_SEED
    )
    model.fit(X_tr, y_tr)
    
    # Iterative forecast: tahminleri history'e ekleyerek ilerle
    history = list(train_data)
    all_future = test_yil + forecast_yil
    predictions = []
    for yil in all_future:
        last_lags = history[-n_lag:]
        x_pred = np.array([[yil] + last_lags])
        y_pred = model.predict(x_pred)[0]
        predictions.append(y_pred)
        history.append(y_pred)
    
    return (np.array(predictions[:len(test_yil)]), 
            np.array(predictions[len(test_yil):]))


def clip_negatif(test_pred, forecast_pred):
    """Revenue >= 0 kisiti: negatif tahminleri 0'a sabit."""
    return np.clip(test_pred, 0, None), np.clip(forecast_pred, 0, None)


def hesapla_metrikler(y_true, y_pred):
    """MAPE, RMSE, MAE hesapla. y_true=0 durumlarinda MAPE NaN."""
    y_true = np.array(y_true)
    y_pred = np.array(y_pred)
    
    mask = y_true > 0.01  # Cok kucuk degerleri filtrele (MAPE patlamasin)
    
    if mask.sum() > 0:
        mape = np.mean(np.abs((y_true[mask] - y_pred[mask]) / y_true[mask])) * 100
    else:
        mape = np.nan
    
    rmse = np.sqrt(np.mean((y_true - y_pred) ** 2))
    mae = np.mean(np.abs(y_true - y_pred))
    
    return mape, rmse, mae


