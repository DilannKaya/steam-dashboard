    print(f"   Hybrid USD (2025 baz):  ${h['revenue_baz_usd']:>15,.0f}")
    if h['finansal_korluk_uyarisi']:
        print(f"\n   {h['finansal_korluk_uyarisi']}")
    
    s = rapor['segment_bilgisi']
    print(f"\n[SEGMENT BILGISI (CAGR)]")
    print(f"   CAGR kaynagi:    {s['cagr_kaynagi']}")
    print(f"   Yillik CAGR:     %{s['cluster_cagr_yuzde']:+.2f}")
    print(f"   Algoritma:       {s['cluster_algoritma']}")
    print(f"   MAPE:            %{s['cluster_mape']:.1f}")
    print(f"   Guven seviyesi:  {s['guven_seviyesi']} (Lewis 1982)")
    if s['fallback_kullanildi']:
        print(f"   ⚠️ FALLBACK:     {s['fallback_sebep']}")
    
    p = rapor['2027_projeksiyon_usd']
    print(f"\n[2027 REVENUE PROJEKSIYONU — 3 SENARYO]")
    print(f"   Worst case (-30%): ${p['worst_case']:>15,.0f}")
    print(f"   Base case:         ${p['base_case']:>15,.0f}  ← Ana tahmin")
    print(f"   Best case (+30%):  ${p['best_case']:>15,.0f}")
    print(f"   Buyume (2025→2027): %{p['buyume_yuzde']:+.2f}")
    
    print(f"\n[YATIRIM ONERISI]")
    print(f"   {rapor['yatirim_onerisi']}")
    print("=" * 80)


