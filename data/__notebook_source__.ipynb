# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. K-NN icin kullanilacak ozellikleri secmek
#   2. Sayisal + Binary + Kategorik ozellikleri birlestirmek
#   3. Eksik degerleri 0 ile doldurmak
#   4. Iki normalizasyon olusturmak: Min-Max ve Z-Skor
# ════════════════════════════════════════════════════════════════════

# ── 1) Sayisal ozellikler ──────────────────────────────────────────
sayisal_ozellikler = [
    'log_wishlists', 'log_copies', 'log_followers', 'log_review_count',
    'Review Score', 'price_usd_clipped', 'log_playtime'
]

# ── 2) Genre binary ozellikleri ────────────────────────────────────
# Not: genre_price_segment string oldugu icin haric tutuluyor
genre_binary = [c for c in df_clean.columns 
                if c.startswith('genre_') 
                and c not in ['genre_list', 'genre_price_segment']]

# ── 3) Tag binary ozellikleri ──────────────────────────────────────
tag_binary = [c for c in df_clean.columns if c.startswith('tag_') and c != 'tag_list']

# ── 4) Feature binary ozellikleri ──────────────────────────────────
feature_binary = [c for c in df_clean.columns if c.startswith('feature_') and c != 'feature_list']

# ── Tum ozellikleri birlestir ─────────────────────────────────────
tum_ozellikler = sayisal_ozellikler + genre_binary + tag_binary + feature_binary

print("=" * 70)
print("OZELLIK MATRISI HAZIRLIGI")
print("=" * 70)
print(f"\nSayisal ozellikler:   {len(sayisal_ozellikler):>3}")
print(f"Genre binary:          {len(genre_binary):>3}")
print(f"Tag binary:            {len(tag_binary):>3}")
print(f"Feature binary:        {len(feature_binary):>3}")
print(f"TOPLAM:                {len(tum_ozellikler):>3}")

# ── Hedef degisken ────────────────────────────────────────────────
hedef = 'log_revenue'
print(f"\nHedef degisken (target): {hedef}")

# ── X (ozellik matrisi) ve y (hedef) olustur ──────────────────────
X = df_clean[tum_ozellikler].fillna(0).copy()
y = df_clean[hedef].fillna(0).copy()

print(f"\nOzellik matrisi X boyutu: {X.shape}")
print(f"Hedef vektoru y boyutu:   {y.shape}")

# ── Eksik veri kontrolu ───────────────────────────────────────────
eksik_X = X.isna().sum().sum()
eksik_y = y.isna().sum()
print(f"\nEksik veri kontrolu:")
print(f"  X'te eksik: {eksik_X}")
print(f"  y'de eksik: {eksik_y}")
if eksik_X > 0 or eksik_y > 0:
    print(f"  UYARI: Eksik degerler var. Bunlari 0 ile dolduralim.")
    X = X.fillna(0)
    y = y.fillna(0)
    print(f"  Sonuc: Eksik degerler dolduruldu.")

# ── Normalizasyon: Min-Max ─────────────────────────────────────────
print("\n" + "=" * 70)
print("NORMALIZASYON")
print("=" * 70)
print("\nAdim 1/2: Min-Max normalizasyon uygulaniyor...")

minmax_scaler = MinMaxScaler()
X_minmax = minmax_scaler.fit_transform(X)
X_minmax_df = pd.DataFrame(X_minmax, columns=tum_ozellikler, index=X.index)

print(f"  Min-Max sonrasi orneklemler (ilk 5 ozellik):")
for col in tum_ozellikler[:5]:
    print(f"    {col:<25} min={X_minmax_df[col].min():.3f}, max={X_minmax_df[col].max():.3f}")

# ── Normalizasyon: Z-Skor ─────────────────────────────────────────
print("\nAdim 2/2: Z-Skor normalizasyon uygulaniyor...")

zscore_scaler = StandardScaler()
X_zscore = zscore_scaler.fit_transform(X)
X_zscore_df = pd.DataFrame(X_zscore, columns=tum_ozellikler, index=X.index)

print(f"  Z-Skor sonrasi orneklemler (ilk 5 ozellik):")
for col in tum_ozellikler[:5]:
    print(f"    {col:<25} ort={X_zscore_df[col].mean():+.3f}, std={X_zscore_df[col].std():.3f}")

# ── Train/Test Split ──────────────────────────────────────────────
from sklearn.model_selection import train_test_split

print("\n" + "=" * 70)
print("TRAIN/TEST SPLIT (80/20)")
print("=" * 70)

# Indices'i bolmek istiyoruz (sonra hangi oyun nereye dustugunu bulmak icin)
indices = np.arange(len(df_clean))
train_idx, test_idx = train_test_split(
    indices, test_size=0.20, random_state=RANDOM_SEED
)

# Hem Min-Max hem Z-Skor icin train/test setleri
X_minmax_train, X_minmax_test = X_minmax[train_idx], X_minmax[test_idx]
X_zscore_train, X_zscore_test = X_zscore[train_idx], X_zscore[test_idx]
y_train, y_test = y.iloc[train_idx].values, y.iloc[test_idx].values

print(f"\nEgitim seti: {len(train_idx):,} oyun (%{len(train_idx)/len(df_clean)*100:.1f})")
print(f"Test seti:   {len(test_idx):,} oyun (%{len(test_idx)/len(df_clean)*100:.1f})")
print(f"\n✓ Ozellik matrisi hazir.")
print(f"✓ 2 normalizasyon (Min-Max, Z-Skor) uygulandi.")
print(f"✓ Train/Test split tamamlandi (80/20).")
print(f"\nSiradaki adim: K-NN algoritmasi (4 mesafe metrigi x 2 normalizasyon = 8 model)")


# ════════════════════════════════════════════════════════════════════
# K-NN ALGORITMASI - 8 MODEL KARSILASTIRMASI
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. 4 mesafe metrigi (Euclidean, Manhattan, Cosine, Chebyshev)
#   2. 2 normalizasyon (Min-Max, Z-Skor)
#   3. Toplam 8 modeli egitmek, karsilastirmak
#   4. En iyi modeli secmek
# ════════════════════════════════════════════════════════════════════

# K sayisi (komsu sayisi)
K = 5

# Mesafe metrikleri
metrikler = {
    'Euclidean': 'euclidean',
    'Manhattan': 'manhattan',
    'Cosine': 'cosine',
    'Chebyshev': 'chebyshev'
}

# Normalizasyonlar
normalizasyonlar = {
    'MinMax': (X_minmax_train, X_minmax_test),
    'ZScore': (X_zscore_train, X_zscore_test)
}

print("=" * 80)
print(f"K-NN MODEL KARSILASTIRMASI (K={K})")
print("=" * 80)
print(f"\n4 metrik × 2 normalizasyon = 8 model egitilecek")
print(f"Egitim seti:  {len(y_train):,} oyun")
print(f"Test seti:    {len(y_test):,} oyun")
print(f"Hedef:        log_revenue\n")

# Sonuclari sakla
knn_sonuclari = []

# Her kombinasyonu dene
for norm_adi, (X_tr, X_te) in normalizasyonlar.items():
    for metrik_adi, metrik in metrikler.items():
        print(f"\nEgitiliyor: {norm_adi} + {metrik_adi}... ", end='')
        start_time = time.time()
        
        # K-NN Regresor olustur ve egit
        knn = KNeighborsRegressor(
            n_neighbors=K,
            metric=metrik,
            n_jobs=-1  # Tum CPU cekirdeklerini kullan
        )
        knn.fit(X_tr, y_train)
        
        # Tahmin
        y_pred = knn.predict(X_te)
        
        # Metrikler
        rmse = np.sqrt(mean_squared_error(y_test, y_pred))
        mae = mean_absolute_error(y_test, y_pred)
        r2 = r2_score(y_test, y_pred)
        
        elapsed = time.time() - start_time
        
        knn_sonuclari.append({
            'Normalizasyon': norm_adi,
            'Metrik': metrik_adi,
            'RMSE': rmse,
            'MAE': mae,
            'R²': r2,
            'Sure (sn)': elapsed
        })
        
        print(f"R²={r2:.4f}, RMSE={rmse:.3f}, MAE={mae:.3f} ({elapsed:.1f}s)")

# ── Sonuclari DataFrame'e cevir ────────────────────────────────────
knn_sonuc_df = pd.DataFrame(knn_sonuclari)
knn_sonuc_df = knn_sonuc_df.sort_values('R²', ascending=False).reset_index(drop=True)

print("\n" + "=" * 80)
print("K-NN MODEL SONUCLARI (R² SIRASIYLA)")
print("=" * 80)
print(f"\n{'Rank':<5} {'Normalizasyon':<15} {'Metrik':<12} {'R²':>10} {'RMSE':>10} {'MAE':>10} {'Sure (s)':>10}")
print("-" * 75)
for i, row in knn_sonuc_df.iterrows():
    print(f"{i+1:<5} {row['Normalizasyon']:<15} {row['Metrik']:<12} "
          f"{row['R²']:>10.4f} {row['RMSE']:>10.3f} {row['MAE']:>10.3f} {row['Sure (sn)']:>10.1f}")

# ── En iyi model ──────────────────────────────────────────────────
en_iyi = knn_sonuc_df.iloc[0]
print(f"\n" + "=" * 80)
print(f"EN IYI K-NN MODEL")
print("=" * 80)
print(f"\n  Normalizasyon: {en_iyi['Normalizasyon']}")
print(f"  Metrik:        {en_iyi['Metrik']}")
print(f"  R² Skoru:      {en_iyi['R²']:.4f}")
print(f"  RMSE:          {en_iyi['RMSE']:.3f}")
print(f"  MAE:           {en_iyi['MAE']:.3f}")

# CSV kaydet
knn_sonuc_df.to_csv(CIKTI_KLASORU + 'knn_model_karsilastirma.csv', index=False)
print(f"\nCSV kaydedildi: {CIKTI_KLASORU}knn_model_karsilastirma.csv")

# ── Gorselleştirme ─────────────────────────────────────────────────
fig, axes = plt.subplots(1, 3, figsize=(18, 6))

# 1) R² karsilastirma
knn_sonuc_df_plot = knn_sonuc_df.copy()
knn_sonuc_df_plot['Model'] = knn_sonuc_df_plot['Normalizasyon'] + '_' + knn_sonuc_df_plot['Metrik']
colors = sns.color_palette('viridis', 8)
