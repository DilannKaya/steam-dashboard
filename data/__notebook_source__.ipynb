# SINIFLANDIRMA SUTUNLARININ URETILMESI
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. 6 farkli siniflandirma sutunu olusturmak
#   2. Sinif dagilimlarini raporlamak
#   3. Domain-based eşikleri kullanmak
# ════════════════════════════════════════════════════════════════════

# ── Yillik ortalama revenue hesapla (revenue_class icin) ──────────
yil_revenue_kolonlari = [f'{y} revenue' for y in range(2015, 2026)]
df_clean['yillik_ort_revenue'] = df_clean[yil_revenue_kolonlari].mean(
    axis=1, skipna=True).fillna(0)

print("=" * 70)
print("SINIFLANDIRMA SUTUNLARININ URETILMESI")
print("=" * 70)

# ════════════════════════════════════════════════════════════════
# 1) REVENUE_CLASS
# ════════════════════════════════════════════════════════════════
def revenue_class(r):
    """Yillik ortalama revenue'ye gore siniflandirma."""
    if r == 0:
        return 'Free'
    elif r < 50_000:        # $50K'in altinda - kucuk
        return 'Mid'
    elif r < 500_000:       # $500K'in altinda - orta
        return 'Premium'
    else:                   # $500K+ - buyuk
        return 'Luxury'

df_clean['revenue_class'] = df_clean['yillik_ort_revenue'].apply(revenue_class)

# ════════════════════════════════════════════════════════════════
# 2) PRICE_CLASS
# ════════════════════════════════════════════════════════════════
def price_class(p):
    """Fiyat segmentasyonu (Steam konvensiyonuna gore)."""
    if pd.isna(p) or p == 0:
        return 'Free'
    elif p < 5:
        return 'Cheap'      # $0-5 indie/casual
    elif p < 15:
        return 'Low'        # $5-15 indie
    elif p < 30:
        return 'Mid'        # $15-30 mid-tier
    elif p < 50:
        return 'Premium'    # $30-50 premium
    else:
        return 'Luxury'     # $50+ AAA

df_clean['price_class'] = df_clean['price_usd'].apply(price_class)

# ════════════════════════════════════════════════════════════════
# 3) WISHLIST_CLASS
# ════════════════════════════════════════════════════════════════
def wishlist_class(w):
    """Wishlist sayisina gore siniflandirma."""
    if pd.isna(w) or w == 0:
        return 'Low'
    elif w < 1_000:
        return 'Low'
    elif w < 10_000:
        return 'Mid'
    elif w < 100_000:
        return 'High'
    else:
        return 'Very High'

df_clean['wishlist_class'] = df_clean['Wishlists'].apply(wishlist_class)

# ════════════════════════════════════════════════════════════════
# 4) REVIEW_CLASS
# ════════════════════════════════════════════════════════════════
def review_class(r):
    """Review skoruna gore siniflandirma (Steam konvensiyonuna gore)."""
    if pd.isna(r):
        return 'No Review'
    elif r < 50:
        return 'Poor'        # Steam: Mostly Negative
    elif r < 70:
        return 'Average'     # Steam: Mixed
    elif r < 85:
        return 'Good'        # Steam: Mostly Positive
    else:
        return 'Excellent'   # Steam: Very Positive / Overwhelmingly Positive

df_clean['review_class'] = df_clean['Review Score'].apply(review_class)

# ════════════════════════════════════════════════════════════════
# 5) FOLLOWERS_CLASS
# ════════════════════════════════════════════════════════════════
def followers_class(f):
    """Takipci sayisina gore siniflandirma."""
    if pd.isna(f) or f == 0:
        return 'Low'
    elif f < 100:
        return 'Low'
    elif f < 1_000:
        return 'Mid'
    else:
        return 'High'

df_clean['followers_class'] = df_clean['Followers'].apply(followers_class)

# ════════════════════════════════════════════════════════════════
# 6) PLAYTIME_CLASS (log uzayinda quartile bazli)
# ════════════════════════════════════════════════════════════════
# Birim belirsiz oldugu icin domain-based yerine quartile kullaniyoruz
pt_nonzero = df_clean.loc[df_clean['log_playtime'] > 0, 'log_playtime']
pt_q33 = pt_nonzero.quantile(0.33)
pt_q66 = pt_nonzero.quantile(0.66)

def playtime_class(p):
    """Log playtime'a gore quartile bazli siniflandirma."""
    if p == 0:
        return 'No Data'
    elif p < pt_q33:
        return 'Short'
    elif p < pt_q66:
        return 'Mid'
    else:
        return 'Long'

df_clean['playtime_class'] = df_clean['log_playtime'].apply(playtime_class)

# ════════════════════════════════════════════════════════════════
# DAGILIMLARI RAPORLA
# ════════════════════════════════════════════════════════════════
sinif_sutunlar = ['revenue_class', 'price_class', 'wishlist_class', 
                  'review_class', 'followers_class', 'playtime_class']

print(f"\n✓ {len(sinif_sutunlar)} siniflandirma sutunu olusturuldu")
print(f"✓ Toplam {len(df_clean):,} oyun siniflandirildi\n")

for col in sinif_sutunlar:
