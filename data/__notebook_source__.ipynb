# GRAFIK 4: GECMIS VS GELECEK CAGR PARADOKSU
# ════════════════════════════════════════════════════════════════

print("\n[4/5] Gecmis-Gelecek CAGR paradoksu cizilliyor...")

# Gercek CAGR (2015-2025)
gecmis_cagr = (((yillik_toplam_gercek[-1] / yillik_toplam_gercek[0]) ** (1/10)) - 1) * 100

# Gelecek CAGR (2025-2027, GUVENILIR)
gelecek_cagr = (((forecast_2027_guv / yillik_toplam_gercek[-1]) ** 0.5) - 1) * 100

fig, ax = plt.subplots(figsize=(14, 7))

# Gercek tarihsel veriler
ax.plot(yillar, yillik_toplam_gercek, marker='o', color='#2E86AB',
        linewidth=2.5, markersize=10, label=f'Gercek pazar (2015-2025, CAGR +%{gecmis_cagr:.1f})')

# Gecmis trend EXTRAPOLE edilirse (eger CAGR %17 devam etseydi)
extrap_yillar = [2025, 2026, 2027]
extrap_degerler = [yillik_toplam_gercek[-1]]
for _ in range(2):
    extrap_degerler.append(extrap_degerler[-1] * (1 + gecmis_cagr/100))

ax.plot(extrap_yillar, extrap_degerler, marker='^', color='#27ae60',
        linewidth=2.5, markersize=12, linestyle='--', alpha=0.7,
        label=f'Iyimser senaryo (gecmis CAGR +%{gecmis_cagr:.1f} devam) → ${extrap_degerler[-1]:.2f}B')

# Model projeksiyonu (GUVENILIR)
forecast_x = [2025] + forecast_yillar
forecast_y = [yillik_toplam_gercek[-1], forecast_2026_guv, forecast_2027_guv]
ax.plot(forecast_x, forecast_y, marker='D', color='#e74c3c',
        linewidth=2.5, markersize=12, linestyle='--',
        label=f'Best-of-Best model (CAGR +%{gelecek_cagr:.1f}) → ${forecast_2027_guv:.2f}B')

# Iki senaryo arasi fark vurgusu
fark_dolar = extrap_degerler[-1] - forecast_2027_guv
ax.fill_between([2025, 2026, 2027], 
                forecast_y, extrap_degerler,
                alpha=0.2, color='red', 
                label=f'Belirsizlik bandi (${fark_dolar:.2f}B fark)')

# Yorum kutusu
ax.text(0.02, 0.98,
        f'PARADOKS:\n'
        f'Gecmis 10 yil CAGR: +%{gecmis_cagr:.1f}\n'
        f'Model 2 yil CAGR:   +%{gelecek_cagr:.1f}\n'
        f'Fark: ~6 kat\n\n'
        f'Aciklama:\n'
        f'1. ARIMA mean-reversion eğilimi\n'
        f'2. Action segmentinde stagnasyon\n'
        f'3. Pazar doygunluğu sinyali',
        transform=ax.transAxes, fontsize=9, verticalalignment='top',
        family='monospace',
        bbox=dict(boxstyle='round,pad=0.5', facecolor='lightyellow', 
                  edgecolor='red', linewidth=1.5))

ax.set_title('Geçmiş Trend vs Model Projeksiyonu — CAGR Paradoksu',
             fontweight='bold', fontsize=13)
ax.set_xlabel('Yil')
ax.set_ylabel('Toplam Revenue (Milyar $)')
ax.legend(loc='lower right', fontsize=10)
ax.grid(alpha=0.3)
ax.set_xlim(2014.5, 2027.7)

