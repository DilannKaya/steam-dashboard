print(f"  Min:    ${df_clean['price_usd'].min():,.2f}")

print(f"\nlog_playtime istatistikleri:")
print(f"  Median: {df_clean['log_playtime'].median():.2f}")
print(f"  Max:    {df_clean['log_playtime'].max():.2f}")
