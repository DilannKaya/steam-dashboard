# ════════════════════════════════════════════════════════════════════
# OPTIMAL KUME SAYISI BELIRLEME (ELBOW + SILHOUETTE)
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. k=2'den k=15'e kadar WCSS ve Silhouette hesapla
#   2. Elbow ve Silhouette grafiklerini ciz
#   3. Optimal k'yi belirle
# ════════════════════════════════════════════════════════════════════

from sklearn.metrics import silhouette_score

from sklearn.metrics import silhouette_score

print("=" * 70)
print("OPTIMAL KUME SAYISI ANALIZI")
print("=" * 70)

# X_kume_scaled hazirla (KMeans hucresiyle ayni)
kume_ozellikler = ['log_revenue', 'log_copies', 'log_wishlists',
                   'log_followers', 'log_review_count', 'price_usd',
                   'Review Score', 'log_playtime']
X_kume = df_clean[kume_ozellikler].copy()
scaler_kume = StandardScaler()
X_kume_scaled = scaler_kume.fit_transform(X_kume)
# Test edilecek k araligi
k_araligi = range(2, 16)

wcss_listesi = []
silhouette_listesi = []

print(f"\n{'k':>3} {'WCSS':>15} {'Silhouette':>12}")
print("-" * 35)

# Hesaplama suresini azaltmak icin orneklem (113K cok buyuk silhouette icin)
ornek_boyut = 10000
np.random.seed(RANDOM_SEED)
ornek_idx = np.random.choice(len(X_kume_scaled), 
                              min(ornek_boyut, len(X_kume_scaled)), 
                              replace=False)
X_ornek = X_kume_scaled[ornek_idx]

for k in k_araligi:
    # KMeans modeli
    km = KMeans(n_clusters=k, n_init=10, random_state=RANDOM_SEED)
    labels = km.fit_predict(X_kume_scaled)
    
    # WCSS (tum veri uzerinde)
    wcss = km.inertia_
    wcss_listesi.append(wcss)
    
    # Silhouette (orneklem uzerinde, hiz icin)
    labels_ornek = labels[ornek_idx]
    if len(np.unique(labels_ornek)) > 1:
        sil = silhouette_score(X_ornek, labels_ornek)
    else:
        sil = 0
    silhouette_listesi.append(sil)
    
    print(f"{k:>3} {wcss:>15,.0f} {sil:>12.4f}")

# ── En iyi k'yi belirle ──
# Silhouette'e gore en iyi
en_iyi_k_silhouette = list(k_araligi)[np.argmax(silhouette_listesi)]

# Elbow noktasini bul (WCSS dususunun en cok yavasladigi nokta)
# Ikinci turev yaklasimi
wcss_arr = np.array(wcss_listesi)
farklar = np.diff(wcss_arr)
ikinci_farklar = np.diff(farklar)
elbow_idx = np.argmax(ikinci_farklar) + 2  # +2 offset (iki diff)
en_iyi_k_elbow = list(k_araligi)[min(elbow_idx, len(list(k_araligi))-1)]

print(f"\n" + "=" * 70)
print("SONUC")
print("=" * 70)
print(f"  Elbow Method onerisi:      k = {en_iyi_k_elbow}")
print(f"  Silhouette Score onerisi:  k = {en_iyi_k_silhouette}")
print(f"  Bu projede secilen:        k = 10")

# ── Gorselleştirme ──
fig, axes = plt.subplots(1, 2, figsize=(16, 6))

# Elbow grafigi
axes[0].plot(list(k_araligi), wcss_listesi, marker='o', linewidth=2, 
             color='#2E86AB', markersize=8)
axes[0].axvline(x=10, color='red', linestyle='--', alpha=0.7, 
                label='Secilen k=10')
axes[0].axvline(x=en_iyi_k_elbow, color='green', linestyle=':', alpha=0.7,
                label=f'Elbow k={en_iyi_k_elbow}')
axes[0].set_title('Elbow Method (WCSS)', fontweight='bold', fontsize=12)
axes[0].set_xlabel('Kume Sayisi (k)')
axes[0].set_ylabel('WCSS (Kume Ici Kareler Toplami)')
axes[0].legend()
axes[0].grid(alpha=0.3)

# Silhouette grafigi
axes[1].plot(list(k_araligi), silhouette_listesi, marker='s', linewidth=2,
             color='#C73E1D', markersize=8)
axes[1].axvline(x=10, color='red', linestyle='--', alpha=0.7,
                label='Secilen k=10')
axes[1].axvline(x=en_iyi_k_silhouette, color='green', linestyle=':', alpha=0.7,
                label=f'En iyi k={en_iyi_k_silhouette}')
axes[1].set_title('Silhouette Score', fontweight='bold', fontsize=12)
axes[1].set_xlabel('Kume Sayisi (k)')
axes[1].set_ylabel('Silhouette Skoru')
axes[1].legend()
axes[1].grid(alpha=0.3)

plt.suptitle('KMeans Optimal Kume Sayisi Analizi', 
             fontsize=14, fontweight='bold', y=1.02)
plt.tight_layout()
plt.savefig(CIKTI_KLASORU + 'kmeans_optimal_k.png', dpi=100, bbox_inches='tight')
plt.show()

print(f"\nGrafik kaydedildi: {CIKTI_KLASORU}kmeans_optimal_k.png")


