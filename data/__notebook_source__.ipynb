# ════════════════════════════════════════════════════════════════════
# CONTENT-BASED FILTERING (BELLEK DOSTU - BATCH PROCESSING)
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. Sadece icerik ozelliklerini kullan (Genre + Tag + Feature)
#   2. Kosinus benzerligi BATCH halinde hesapla (bellek tasmasini onler)
#   3. Test seti icin en benzer 5 oyunun ortalama log_revenue'sunu tahmin et
# ════════════════════════════════════════════════════════════════════

print("=" * 70)
print("CONTENT-BASED FILTERING (BATCH PROCESSING)")
print("=" * 70)

# ── Icerik ozellikleri ─────────────────────────────────────────────
icerik_ozellikler = genre_binary + tag_binary + feature_binary
print(f"\nIcerik ozellikleri: {len(icerik_ozellikler)} adet")

# Float32 kullaniyoruz - bellek tasarrufu icin (float64 yerine)
X_content = df_clean[icerik_ozellikler].fillna(0).values.astype(np.float32)
X_content_train = X_content[train_idx]
X_content_test = X_content[test_idx]

print(f"\nIcerik matrisi train: {X_content_train.shape}, dtype: {X_content_train.dtype}")
print(f"Icerik matrisi test:  {X_content_test.shape}")
print(f"Tahmini bellek (train): {X_content_train.nbytes / 1024**2:.1f} MB")

# ── BATCH PROCESSING ──────────────────────────────────────────────
# Tum test orneklerini bir kerede yerine, 500'erli batch'ler halinde isle
K_cb = 5
BATCH_SIZE = 500

n_test = len(X_content_test)
n_batches = (n_test + BATCH_SIZE - 1) // BATCH_SIZE

print(f"\nBatch processing:")
print(f"  Toplam test ornegi: {n_test:,}")
print(f"  Batch sayisi:       {n_batches}")
print(f"  Batch boyutu:       {BATCH_SIZE}")

# Sonuclari saklayacak array'ler
y_pred_content = np.zeros(n_test, dtype=np.float32)
en_benzer_indices_all = np.zeros((n_test, K_cb), dtype=np.int32)

start_time = time.time()

for batch_idx in range(n_batches):
    # Batch sinirlari
    start_i = batch_idx * BATCH_SIZE
    end_i = min(start_i + BATCH_SIZE, n_test)
    
    # Bu batch icin benzerligi hesapla (kucuk: 500 x 90764)
    batch_benzerlik = cosine_similarity(
        X_content_test[start_i:end_i], 
        X_content_train
    )
    
    # En benzer K'yi bul ve y_pred hesapla
    for i in range(end_i - start_i):
        top_k = np.argsort(-batch_benzerlik[i])[:K_cb]
        en_benzer_indices_all[start_i + i] = top_k
        y_pred_content[start_i + i] = y_train[top_k].mean()
    
    # Bellegi temizle
    del batch_benzerlik
    
    # Progress
    if (batch_idx + 1) % 5 == 0 or batch_idx == n_batches - 1:
        elapsed = time.time() - start_time
        progress = (batch_idx + 1) / n_batches * 100
        print(f"  Batch {batch_idx+1}/{n_batches} ({progress:.0f}%) - {elapsed:.1f}s")

total_time = time.time() - start_time
print(f"\nTamamlandi: {total_time:.1f} saniye")

# ── Metrikler ─────────────────────────────────────────────────────
rmse_cb = np.sqrt(mean_squared_error(y_test, y_pred_content))
mae_cb = mean_absolute_error(y_test, y_pred_content)
r2_cb = r2_score(y_test, y_pred_content)

print("\n" + "=" * 70)
print("CONTENT-BASED FILTERING SONUCLARI")
print("=" * 70)
print(f"\n  R² Skoru:  {r2_cb:.4f}")
print(f"  RMSE:      {rmse_cb:.3f}")
print(f"  MAE:       {mae_cb:.3f}")

# ── K-NN ile karsilastirma ────────────────────────────────────────
print("\n" + "=" * 70)
print("K-NN (EN IYI) VS CONTENT-BASED KARSILASTIRMA")
print("=" * 70)

print(f"\n{'Model':<35} {'R²':>10} {'RMSE':>10} {'MAE':>10}")
print("-" * 70)
print(f"{'K-NN (ZScore + Manhattan)':<35} {en_iyi['R²']:>10.4f} {en_iyi['RMSE']:>10.3f} {en_iyi['MAE']:>10.3f}")
print(f"{'Content-Based (Cosine)':<35} {r2_cb:>10.4f} {rmse_cb:>10.3f} {mae_cb:>10.3f}")

print(f"\nFark (K-NN - CB):")
print(f"  ΔR²:    {en_iyi['R²'] - r2_cb:+.4f}")
print(f"  ΔRMSE:  {en_iyi['RMSE'] - rmse_cb:+.3f}")
print(f"  ΔMAE:   {en_iyi['MAE'] - mae_cb:+.3f}")

if en_iyi['R²'] > r2_cb:
    print(f"\n  Sonuc: K-NN, Content-Based'i {(en_iyi['R²'] - r2_cb)*100:.1f}% R² farkla yendi.")
    print(f"         Sayisal ozellikler (log_wishlists vb.) onemli bilgi tasiyor.")
else:
    print(f"\n  Sonuc: Content-Based, K-NN'i {(r2_cb - en_iyi['R²'])*100:.1f}% R² farkla yendi.")

# ── Sonuclari kaydet ──────────────────────────────────────────────
tum_sonuclar = knn_sonuc_df.copy()
tum_sonuclar.loc[len(tum_sonuclar)] = {
    'Normalizasyon': 'N/A',
    'Metrik': 'Cosine (Content)',
    'R²': r2_cb,
    'RMSE': rmse_cb,
    'MAE': mae_cb,
    'Sure (sn)': total_time
}
tum_sonuclar = tum_sonuclar.sort_values('R²', ascending=False).reset_index(drop=True)
tum_sonuclar.to_csv(CIKTI_KLASORU + 'tum_oneri_modelleri_karsilastirma.csv', index=False)
print(f"\nCSV kaydedildi: {CIKTI_KLASORU}tum_oneri_modelleri_karsilastirma.csv")

# ── Ornek Oneri Cikarma ────────────────────────────────────────────
print("\n" + "=" * 70)
print("ORNEK ONERI: TEST SETINDEKI ILK 3 OYUN ICIN")
print("=" * 70)

for i in range(3):
    test_oyun_idx = test_idx[i]
    test_oyun_adi = df_clean.iloc[test_oyun_idx]['Name']
    test_oyun_genre = df_clean.iloc[test_oyun_idx]['primary_genre']
    
    # En benzer 5 oyunun train index'lerini al
    en_benzer_train_indices = en_benzer_indices_all[i]
    gercek_indices = train_idx[en_benzer_train_indices]
    
    print(f"\nHedef Oyun: {test_oyun_adi}  (Genre: {test_oyun_genre})")
    print(f"En benzer 5 oyun (Content-Based):")
    for j, idx in enumerate(gercek_indices, 1):
        oyun = df_clean.iloc[idx]
        print(f"  {j}. {str(oyun['Name'])[:45]:<45} (Genre: {oyun['primary_genre']})")

print(f"\n✓ Content-Based Filtering tamamlandi.")


