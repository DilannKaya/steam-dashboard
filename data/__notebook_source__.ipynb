    print(f"{genre:<22} {row['oyun_sayisi']:>8,.0f} "
          f"${row['ort_revenue']/1000:>9,.0f}K ${row['median_revenue']:>8,.0f} "
          f"${row['toplam_revenue']/1e9:>13,.2f}B "
