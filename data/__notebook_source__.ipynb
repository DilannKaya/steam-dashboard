# CONTENT-BASED ICIN UYGUN ORNEK ONERILER
# ════════════════════════════════════════════════════════════════════
# Onceki ornek oyunlar 18+ icerikli oldugu icin, akademik raporda 
# uygun olacak sekilde POPULER/TANINIRLI oyunlar uzerinden ornek
# oneriler uretilecek.
# ════════════════════════════════════════════════════════════════════

print("=" * 70)
print("CONTENT-BASED FILTERING: POPULER OYUNLAR ICIN ORNEK ONERILER")
print("=" * 70)

# Test setindeki en yuksek wishlistli oyunlari sec (taninir olanlar)
test_oyunlari = df_clean.iloc[test_idx].copy()
test_oyunlari['test_pos'] = range(len(test_oyunlari))  # test setindeki pozisyon

# Wishlist'i yuksek olan ilk 5 oyunu sec (taninir)
populer_test = test_oyunlari.nlargest(5, 'Wishlists')

print(f"\nSecilen ornek oyunlar (yuksek wishlistli, taninir):")
for _, row in populer_test.iterrows():
    print(f"  • {row['Name']}  (Wishlists: {row['Wishlists']:,.0f})")

# Her biri icin Content-Based en benzer 5 oyunu goster
for _, row in populer_test.iterrows():
    test_pos = int(row['test_pos'])
    test_oyun_adi = row['Name']
    test_oyun_genre = row['primary_genre']
    test_oyun_wishlists = row['Wishlists']
    
    # Bu oyunun benzerlik indices'i
    en_benzer_train_indices = en_benzer_indices_all[test_pos]
    gercek_indices = train_idx[en_benzer_train_indices]
    
    print(f"\n{'═' * 70}")
    print(f"Hedef Oyun: {test_oyun_adi}")
    print(f"  Genre: {test_oyun_genre}  |  Wishlists: {test_oyun_wishlists:,.0f}")
    print(f"  Revenue: ${df_clean.iloc[test_idx[test_pos]]['Revenue']:,.0f}")
    print(f"{'─' * 70}")
    print(f"En benzer 5 oyun (Content-Based, sadece icerik):")
    
    for j, idx in enumerate(gercek_indices, 1):
        oyun = df_clean.iloc[idx]
        oyun_revenue = oyun['Revenue']
        oyun_wishlists = oyun['Wishlists']
        rev_str = f"${oyun_revenue/1e6:.1f}M" if oyun_revenue >= 1e6 else f"${oyun_revenue:,.0f}"
        print(f"  {j}. {str(oyun['Name'])[:40]:<40} | {oyun['primary_genre']:<12} | Rev: {rev_str}")

print(f"\n✓ Akademik raporda kullanilabilecek ornek oneriler hazirlandi.")








# ════════════════════════════════════════════════════════════════════
# HYBRID STACKING (META-LEARNER)
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. K-NN ve Content-Based tahminlerini SEVIYE 1 olarak kullan
#   2. Linear Regression ile bu tahminleri agirliklandirilarak birlestir
#   3. Tek tek modellerle karsilastir
# ════════════════════════════════════════════════════════════════════

print("=" * 70)
print("HYBRID STACKING - ENSEMBLE LEARNING")
print("=" * 70)

# ── Adim 1: K-NN train tahmini olustur ─────────────────────────────
# (En iyi K-NN modelini kullanacagiz: ZScore + Manhattan)
print(f"\nAdim 1/4: K-NN train tahmini hesaplaniyor...")
print(f"  Model: ZScore + Manhattan (K={K})")

start_time = time.time()
knn_best = KNeighborsRegressor(n_neighbors=K, metric='manhattan', n_jobs=-1)
knn_best.fit(X_zscore_train, y_train)

# Train ve test tahminleri
y_pred_knn_train = knn_best.predict(X_zscore_train)
y_pred_knn_test = knn_best.predict(X_zscore_test)
print(f"  Sure: {time.time() - start_time:.1f}s")
print(f"  Train R²: {r2_score(y_train, y_pred_knn_train):.4f}")
print(f"  Test R²:  {r2_score(y_test, y_pred_knn_test):.4f}")

# ── Adim 2: Content-Based train tahmini olustur ────────────────────
print(f"\nAdim 2/4: Content-Based train tahmini hesaplaniyor (BATCH)...")
start_time = time.time()

# Train icin Content-Based tahminleri (kendi kendine de leak olmamasi icin K=5+1, ilkini at)
n_train = len(X_content_train)
n_batches_tr = (n_train + BATCH_SIZE - 1) // BATCH_SIZE

y_pred_content_train = np.zeros(n_train, dtype=np.float32)
K_train = 6  # +1 cunku kendisi en yakindir, onu atip 5 alacagiz

for batch_idx in range(n_batches_tr):
    start_i = batch_idx * BATCH_SIZE
    end_i = min(start_i + BATCH_SIZE, n_train)
    
    batch_benzerlik = cosine_similarity(
        X_content_train[start_i:end_i], 
        X_content_train
    )
    
    for i in range(end_i - start_i):
        # En yakin K+1, ilkini at (kendisi)
        top_k = np.argsort(-batch_benzerlik[i])[1:K_train]
        y_pred_content_train[start_i + i] = y_train[top_k].mean()
    
    del batch_benzerlik
    
    if (batch_idx + 1) % 20 == 0 or batch_idx == n_batches_tr - 1:
        elapsed = time.time() - start_time
        print(f"  Train batch {batch_idx+1}/{n_batches_tr} - {elapsed:.0f}s")

# Test tahminleri zaten var: y_pred_content
y_pred_content_test = y_pred_content

print(f"  Train R²: {r2_score(y_train, y_pred_content_train):.4f}")
print(f"  Test R²:  {r2_score(y_test, y_pred_content_test):.4f}")

# ── Adim 3: Meta-learner (Linear Regression) ─────────────────────
print(f"\nAdim 3/4: Meta-learner (Linear Regression) egitiliyor...")

# Seviye 1 tahminleri "yeni ozellikler"
X_stacking_train = np.column_stack([y_pred_knn_train, y_pred_content_train])
X_stacking_test = np.column_stack([y_pred_knn_test, y_pred_content_test])

meta_learner = LinearRegression()
meta_learner.fit(X_stacking_train, y_train)

# Hybrid tahminler
y_pred_hybrid = meta_learner.predict(X_stacking_test)

# Meta-learner agirliklarini goster
print(f"\n  Meta-learner egitildi.")
print(f"  Ogrenen agirliklar:")
print(f"    K-NN agirligi:          {meta_learner.coef_[0]:+.4f}")
print(f"    Content-Based agirligi: {meta_learner.coef_[1]:+.4f}")
print(f"    Sabit (intercept):      {meta_learner.intercept_:+.4f}")

# ── Adim 4: Karsilastirma ────────────────────────────────────────
print(f"\nAdim 4/4: Tum modellerin karsilastirmasi")
print("=" * 70)

rmse_hybrid = np.sqrt(mean_squared_error(y_test, y_pred_hybrid))
mae_hybrid = mean_absolute_error(y_test, y_pred_hybrid)
r2_hybrid = r2_score(y_test, y_pred_hybrid)

# Karsilastirma tablosu
karsilastirma = pd.DataFrame({
    'Model': ['K-NN (ZScore + Manhattan)', 'Content-Based (Cosine)', 'Hybrid Stacking'],
    'R²': [en_iyi['R²'], r2_cb, r2_hybrid],
    'RMSE': [en_iyi['RMSE'], rmse_cb, rmse_hybrid],
    'MAE': [en_iyi['MAE'], mae_cb, mae_hybrid]
})

print(f"\n{'Model':<35} {'R²':>10} {'RMSE':>10} {'MAE':>10}")
