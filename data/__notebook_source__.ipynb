for i, ozellik in enumerate(kmeans_ozellikler, 1):
    print(f"  {i}. {ozellik}")

# ── Eksik degerleri 0 ile doldur (gereken yerlerde) ───────────────
X_kmeans = df_clean[kmeans_ozellikler].fillna(0).copy()

print(f"\nVeri matrisi boyutu: {X_kmeans.shape}")

# ── Z-Skor Normalizasyon ──────────────────────────────────────────
