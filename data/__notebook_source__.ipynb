# GENRE / TAG / FEATURE ONE-HOT ENCODING
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. String formatindaki listeleri parse etmek
#   2. En anlamli genre/tag/feature'lari secmek
#   3. One-hot encoding uygulamak
#   4. df_clean'e binary sutunlar olarak eklemek
# ════════════════════════════════════════════════════════════════════

# ── Parse fonksiyonu (genre icin kullanmistik) ────────────────────
def parse_liste(s):
    """Python liste formatindaki string'i parse eder."""
    if pd.isna(s) or s == '':
        return []
    s = str(s).strip()
    s = s.replace('[', '').replace(']', '')
    s = s.replace('"', '').replace("'", '')
    return [x.strip() for x in s.split(',') if x.strip()]

# ════════════════════════════════════════════════════════════════
# 1) GENRE ONE-HOT (12 anlamli genre)
# ════════════════════════════════════════════════════════════════
print("=" * 70)
print("1) GENRE ONE-HOT ENCODING (12 anlamli genre)")
print("=" * 70)

# EDA'da belirlenen 12 anlamli genre
anlamli_genres = [
    'Indie', 'Casual', 'Action', 'Adventure', 'Simulation', 'Strategy',
    'RPG', 'Free To Play', 'Early Access', 'Sports', 'Racing',
    'Massively Multiplayer'
]

# Her oyunun genre listesini cikar
df_clean['genre_list'] = df_clean['Genres'].apply(parse_liste)

# Her anlamli genre icin binary sutun olustur
for genre in anlamli_genres:
    col_name = f'genre_{genre.lower().replace(" ", "_")}'
    df_clean[col_name] = df_clean['genre_list'].apply(
        lambda lst: 1 if genre in lst else 0
    )

# Ozet
genre_one_hot_kolonlari = [c for c in df_clean.columns if c.startswith('genre_') and c != 'genre_list']
print(f"\n✓ {len(genre_one_hot_kolonlari)} genre sutunu olusturuldu")

# Frekanslar
print(f"\n{'Genre':<30} {'Oyun Sayisi':>12} {'Yuzde':>8}")
print("-" * 55)
for col in genre_one_hot_kolonlari:
    sayisi = df_clean[col].sum()
    yuzde = sayisi / len(df_clean) * 100
    genre_adi = col.replace('genre_', '').replace('_', ' ').title()
    print(f"{genre_adi:<30} {sayisi:>12,} {yuzde:>7.1f}%")

# ════════════════════════════════════════════════════════════════
# 2) TAGS ONE-HOT (Top 30)
# ════════════════════════════════════════════════════════════════
print("\n" + "=" * 70)
print("2) TAGS ONE-HOT ENCODING (Top 30)")
print("=" * 70)

# Tum tag'leri say
df_clean['tag_list'] = df_clean['Tags'].apply(parse_liste)

tag_counter = Counter()
for taglist in df_clean['tag_list']:
    for t in taglist:
        tag_counter[t] += 1

# Top 30
top_30_tags = [tag for tag, _ in tag_counter.most_common(30)]

# One-hot
for tag in top_30_tags:
    # Sutun adi temizle (ozel karakterler)
    safe_name = tag.lower().replace(' ', '_').replace('-', '_').replace("'", '')
    safe_name = ''.join(c for c in safe_name if c.isalnum() or c == '_')
    col_name = f'tag_{safe_name}'
    df_clean[col_name] = df_clean['tag_list'].apply(
        lambda lst: 1 if tag in lst else 0
    )

tag_one_hot_kolonlari = [c for c in df_clean.columns if c.startswith('tag_') and c != 'tag_list']
print(f"\n✓ {len(tag_one_hot_kolonlari)} tag sutunu olusturuldu")

print(f"\nTop 10 Tag:")
print(f"{'Tag':<35} {'Oyun Sayisi':>12} {'Yuzde':>8}")
print("-" * 60)
for tag, count in tag_counter.most_common(10):
    yuzde = count / len(df_clean) * 100
    print(f"{tag[:33]:<35} {count:>12,} {yuzde:>7.1f}%")

# ════════════════════════════════════════════════════════════════
# 3) FEATURES ONE-HOT (Top 30)
# ════════════════════════════════════════════════════════════════
print("\n" + "=" * 70)
print("3) FEATURES ONE-HOT ENCODING (Top 30)")
print("=" * 70)

df_clean['feature_list'] = df_clean['Features'].apply(parse_liste)

feature_counter = Counter()
for flist in df_clean['feature_list']:
    for f in flist:
        feature_counter[f] += 1

top_30_features = [f for f, _ in feature_counter.most_common(30)]

for feat in top_30_features:
    safe_name = feat.lower().replace(' ', '_').replace('-', '_').replace("'", '')
    safe_name = ''.join(c for c in safe_name if c.isalnum() or c == '_')
    col_name = f'feature_{safe_name}'
    df_clean[col_name] = df_clean['feature_list'].apply(
        lambda lst: 1 if feat in lst else 0
    )

feature_one_hot_kolonlari = [c for c in df_clean.columns if c.startswith('feature_') and c != 'feature_list']
print(f"\n✓ {len(feature_one_hot_kolonlari)} feature sutunu olusturuldu")

print(f"\nTop 10 Feature:")
print(f"{'Feature':<35} {'Oyun Sayisi':>12} {'Yuzde':>8}")
print("-" * 60)
for feat, count in feature_counter.most_common(10):
    yuzde = count / len(df_clean) * 100
    print(f"{feat[:33]:<35} {count:>12,} {yuzde:>7.1f}%")

# ════════════════════════════════════════════════════════════════
# OZET
# ════════════════════════════════════════════════════════════════
print("\n" + "=" * 70)
print("ONE-HOT ENCODING ANI - OZET")
print("=" * 70)
print(f"\nOlusturulan binary sutun sayilari:")
print(f"  Genre sutunlari:    {len(genre_one_hot_kolonlari):>3}")
print(f"  Tag sutunlari:      {len(tag_one_hot_kolonlari):>3}")
print(f"  Feature sutunlari:  {len(feature_one_hot_kolonlari):>3}")
print(f"  TOPLAM:             {len(genre_one_hot_kolonlari) + len(tag_one_hot_kolonlari) + len(feature_one_hot_kolonlari):>3}")

print(f"\nFinal df_clean boyutu: {df_clean.shape}")
print(f"\nNot: 'genre_list', 'tag_list', 'feature_list' yardimci sutunlar tutulacak")
print(f"      (sonraki bolumlerde gerekebilir)")














