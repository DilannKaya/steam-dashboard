# GENRE BAZLI SEGMENTASYON
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. Her oyuna primary genre atamak
#   2. Genre segmentlerini profillemek
#   3. Segment bazli analiz yapmak
# ════════════════════════════════════════════════════════════════════

# ── Primary genre atama fonksiyonu ────────────────────────────────
# EDA'da belirlenen 12 anlamli genre (sirali)
anlamli_genres = [
    'Indie', 'Casual', 'Action', 'Adventure', 'Simulation', 'Strategy',
    'RPG', 'Free To Play', 'Early Access', 'Sports', 'Racing',
    'Massively Multiplayer'
]

def primary_genre_ata(genre_list):
    """Anlamli genre listesinden ilk eslesen genre'i dondurur."""
    if not genre_list:
        return 'Other'
    for ag in anlamli_genres:
        if ag in genre_list:
            return ag
    return 'Other'

df_clean['primary_genre'] = df_clean['genre_list'].apply(primary_genre_ata)

# ── Genre dagilimi ────────────────────────────────────────────────
print("=" * 70)
