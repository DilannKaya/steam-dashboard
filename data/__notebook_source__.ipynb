# ════════════════════════════════════════════════════════════════════
# KORELASYON MATRISI ANALIZI
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. Sayisal degiskenler arasi Pearson korelasyonu hesaplamak
#   2. Log donusumu uygulayarak outlier etkisini azaltmak
#   3. Multicollinearity tespiti yapmak
#   4. Revenue ile en yuksek korelasyonlu degiskenleri belirlemek
# ════════════════════════════════════════════════════════════════════

# ── Korelasyon icin sutun secimi ──────────────────────────────────
korelasyon_sutunlar = ['Revenue', 'Copies sold', 'Wishlists', 'Review Score', 
                        'Review count', 'Followers', 'Average playtime', '$ Price']

# NaN'lari 0 ile doldur
df_kor = df[korelasyon_sutunlar].fillna(0).copy()

# Log donusumu uygula (Review Score haric, cunku zaten 0-100 araliginda)
df_kor_log = df_kor.copy()
for col in korelasyon_sutunlar:
    if col != 'Review Score':
        df_kor_log[col] = np.log1p(df_kor[col])

# ── Korelasyon hesapla ────────────────────────────────────────────
korelasyon = df_kor_log.corr()

print("=" * 70)
print("PEARSON KORELASYON MATRISI (LOG DONUSUMLU)")
print("=" * 70)
print("\nDegerler: -1 (mukemmel negatif) ile +1 (mukemmel pozitif)")
print()
print(korelasyon.round(3).to_string())

# ── Revenue ile korelasyonlar (siralanmis) ─────────────────────────
print("\n" + "=" * 70)
print("REVENUE ILE EN YUKSEK KORELASYONLAR")
print("=" * 70)

rev_kor = korelasyon['Revenue'].drop('Revenue').abs().sort_values(ascending=False)

print(f"\n{'Degisken':<25} {'Korelasyon':>15} {'Yorum':<35}")
print("-" * 80)
for col in rev_kor.index:
    r_val = korelasyon.loc[col, 'Revenue']
    abs_r = abs(r_val)
    yon = "+" if r_val > 0 else "-"
    if abs_r >= 0.9:
        yorum = "Cok guclu pozitif"
    elif abs_r >= 0.7:
        yorum = "Guclu pozitif"
    elif abs_r >= 0.5:
        yorum = "Orta pozitif"
    elif abs_r >= 0.3:
        yorum = "Zayif pozitif"
    else:
        yorum = "Iliski yok / cok zayif"
    print(f"{col:<25} {yon}{abs_r:>13.3f}   {yorum:<35}")

# ── Multicollinearity uyarisi ──────────────────────────────────────
print("\n" + "=" * 70)
print("MULTICOLLINEARITY KONTROLU (r > 0.85)")
print("=" * 70)

high_corr_pairs = []
for i in range(len(korelasyon_sutunlar)):
    for j in range(i+1, len(korelasyon_sutunlar)):
        r = korelasyon.iloc[i, j]
        if abs(r) > 0.85:
            high_corr_pairs.append((korelasyon_sutunlar[i], korelasyon_sutunlar[j], r))

if high_corr_pairs:
    print(f"\n{'Degisken 1':<20} {'Degisken 2':<20} {'r':>10}")
    print("-" * 55)
    for v1, v2, r in high_corr_pairs:
        print(f"{v1:<20} {v2:<20} {r:>10.3f}")
    print(f"\nUyari: Bu degiskenler birbirleriyle COK yuksek korelasyonlu.")
    print(f"       Birlikte regresyon modelinde kullanildiklarinda")
    print(f"       multicollinearity problemine yol acabilir.")
else:
    print("\nYuksek korelasyonlu (>0.85) cift bulunamadi.")
    print("Modelleme acisindan multicollinearity sorunu olmayacaktir.")

# ── Gorselleştirme: Heatmap ───────────────────────────────────────
fig, ax = plt.subplots(figsize=(11, 9))
sns.heatmap(korelasyon, annot=True, fmt='.3f', cmap='RdBu_r', center=0,
             vmin=-1, vmax=1, square=True, linewidths=1, ax=ax,
             cbar_kws={'label': 'Korelasyon Katsayisi'},
             annot_kws={'fontsize': 10, 'fontweight': 'bold'})
ax.set_title('Sayisal Degiskenler Arasi Korelasyon Matrisi\n(Log Donusumlu)', 
              fontsize=13, fontweight='bold', pad=15)
plt.tight_layout()
plt.savefig(CIKTI_KLASORU + 'eda_05_korelasyon.png', dpi=100, bbox_inches='tight')
plt.show()

print(f"\nGrafik kaydedildi: {CIKTI_KLASORU}eda_05_korelasyon.png")

# CSV kaydet
korelasyon.to_csv(CIKTI_KLASORU + 'eda_korelasyon_matrisi.csv')
print(f"CSV kaydedildi: {CIKTI_KLASORU}eda_korelasyon_matrisi.csv")














