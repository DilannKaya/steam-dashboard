# SENARYO B: YENI OYUN PLANLAMA FONKSIYONU
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. Yeni bir oyun profili icin tam karar destek raporu uretmek
#   2. Cold-start problemine cozum sunmak
#   3. Strateji onerisi yapmak
# ════════════════════════════════════════════════════════════════════

def senaryo_b_yeni_oyun_planlama(yeni_oyun_profil, df_clean, en_iyi_segmentler, K=5):
    """
    Yeni bir oyun profili icin tam karar destek raporu uretir.
    
    Parameters:
    -----------
    yeni_oyun_profil : dict
        {
            'genre': str,           # 'Action', 'Indie', vs.
            'fiyat': float,         # USD
            'tahmin_wishlist': int, # Tahmini wishlist (opsiyonel)
            'tahmin_review': int    # Tahmini review skoru 0-100 (opsiyonel)
        }
    """
    
    genre = yeni_oyun_profil['genre']
    fiyat = yeni_oyun_profil['fiyat']
    tahmin_wishlist = yeni_oyun_profil.get('tahmin_wishlist', None)
    tahmin_review = yeni_oyun_profil.get('tahmin_review', None)
    
    # ── 1) BENZER MEVCUT OYUNLAR FILTRESI ─────────────────────────
    fiyat_alt = fiyat * 0.5
    fiyat_ust = fiyat * 1.5
    
    filtre = (
        (df_clean['primary_genre'] == genre) &
        (df_clean['price_usd'] >= fiyat_alt) &
        (df_clean['price_usd'] <= fiyat_ust)
    )
    
    aday_oyunlar = df_clean[filtre].copy()
    
    if len(aday_oyunlar) < 5:
        # Fiyat kriterini gevşet
        filtre = df_clean['primary_genre'] == genre
        aday_oyunlar = df_clean[filtre].copy()
    
    # ── 2) WISHLIST-BAZLI EN YAKIN 5 OYUN ─────────────────────────
    if tahmin_wishlist is not None and len(aday_oyunlar) > 0:
        # Wishlist'i tahmine en yakın olan 5
        aday_oyunlar['wishlist_fark'] = abs(aday_oyunlar['Wishlists'] - tahmin_wishlist)
        en_benzer_5 = aday_oyunlar.nsmallest(K, 'wishlist_fark')
    else:
        # Wishlist yoksa rastgele 5 al (ya da median'a yakın)
        if len(aday_oyunlar) > 0:
            median_wl = aday_oyunlar['Wishlists'].median()
            aday_oyunlar['wishlist_fark'] = abs(aday_oyunlar['Wishlists'] - median_wl)
            en_benzer_5 = aday_oyunlar.nsmallest(K, 'wishlist_fark')
        else:
            en_benzer_5 = pd.DataFrame()
    
    benzer_oyunlar = []
    for _, b in en_benzer_5.iterrows():
        benzer_oyunlar.append({
            'Ad': b['Name'],
            'Fiyat': b['price_usd'],
            'Wishlist': b['Wishlists'],
            'Revenue': b['Revenue'],
            'Review': b['Review Score']
        })
    
    if len(en_benzer_5) > 0:
        benzer_ort_revenue = en_benzer_5['Revenue'].mean()
        benzer_ort_review = en_benzer_5['Review Score'].mean()
    else:
        benzer_ort_revenue = 0
        benzer_ort_review = 70
    
    # ── 3) GENRE SEGMENT TAHMINI ──────────────────────────────────
    genre_proj = en_iyi_segmentler[
        (en_iyi_segmentler['Tip'] == 'Genre') & 
        (en_iyi_segmentler['Segment'] == genre)
    ]
    
    if len(genre_proj) > 0:
        genre_row = genre_proj.iloc[0]
        genre_2025 = genre_row['Gercek_2025']
        genre_2027 = genre_row['Forecast_2027']
        genre_buyume = (genre_2027 - genre_2025) / genre_2025 if genre_2025 > 0 else 0
        genre_mape = genre_row['MAPE']
        genre_algo = genre_row['Algoritma']
    else:
        genre_buyume = 0
        genre_mape = 100
        genre_algo = 'N/A'
    
    # ── 4) HIBRIT TAHMIN ─────────────────────────────────────────
    bazis = benzer_ort_revenue
    base_2027 = bazis * (1 + genre_buyume)
    worst_2027 = base_2027 * 0.50  # Yeni oyun icin daha geniş aralık
    best_2027 = base_2027 * 1.50
    
    # ── 5) STRATEJI ANALIZI ──────────────────────────────────────
    # Pazar payi (genre'in pazardaki büyüklüğü)
    genre_oyun_sayisi = (df_clean['primary_genre'] == genre).sum()
    genre_pazar_pay = genre_oyun_sayisi / len(df_clean) * 100
    
    # Rekabet seviyesi
    if genre_oyun_sayisi > 50_000:
        rekabet = 'COK YUKSEK'
        rekabet_aciklama = 'Bu segmentte yogun rekabet var. Diferansiyasyon kritik.'
    elif genre_oyun_sayisi > 10_000:
        rekabet = 'YUKSEK'
        rekabet_aciklama = 'Rekabet yogun ama yer var. Pazarlama bütcesi onemli.'
    elif genre_oyun_sayisi > 1_000:
        rekabet = 'ORTA'
        rekabet_aciklama = 'Yeterli rekabet. Kalite ile one cikilabilir.'
    else:
        rekabet = 'DUSUK'
        rekabet_aciklama = 'Nis pazar. Az rekabet ama kucuk hedef kitle.'
    
    # Wishlist hedef gerçekçiliği
    if tahmin_wishlist is not None:
        wishlist_uzeri = (df_clean[df_clean['primary_genre'] == genre]['Wishlists'] >= tahmin_wishlist).sum()
        wishlist_oran = wishlist_uzeri / genre_oyun_sayisi * 100 if genre_oyun_sayisi > 0 else 0
        
        if wishlist_oran > 50:
            wishlist_yorum = 'Cok kolay erisilir hedef.'
        elif wishlist_oran > 20:
            wishlist_yorum = 'Realistik hedef.'
        elif wishlist_oran > 5:
            wishlist_yorum = 'Zorlu ama mumkun hedef.'
        else:
            wishlist_yorum = 'Cok agresif hedef, dikkatli olunmalı.'
    else:
        wishlist_oran = None
        wishlist_yorum = 'Hedef belirlenmedi.'
    
    # ── 6) RISK SKORU ─────────────────────────────────────────────
    if genre_mape < 10:
        risk_seviyesi = 'DUSUK'
    elif genre_mape < 25:
        risk_seviyesi = 'ORTA'
    else:
        risk_seviyesi = 'YUKSEK'
    
    # ── 7) RAPOR ──────────────────────────────────────────────────
    rapor = {
        'profil': yeni_oyun_profil,
        'benzer_oyunlar': benzer_oyunlar,
        'benzer_ort_revenue': benzer_ort_revenue,
        'benzer_ort_review': benzer_ort_review,
        'genre_segment': genre,
        'genre_buyume': genre_buyume,
        'genre_mape': genre_mape,
        'genre_algo': genre_algo,
        'genre_pazar_pay': genre_pazar_pay,
        'genre_oyun_sayisi': genre_oyun_sayisi,
        'rekabet_seviyesi': rekabet,
        'rekabet_aciklama': rekabet_aciklama,
        'wishlist_oran': wishlist_oran,
        'wishlist_yorum': wishlist_yorum,
        'bazis': bazis,
        '2027_worst': worst_2027,
        '2027_base': base_2027,
        '2027_best': best_2027,
        'risk_seviyesi': risk_seviyesi
    }
    
    return rapor


def yazdir_senaryo_b(rapor):
    """Senaryo B raporunu okunabilir formatta yazdirir."""
    print("=" * 80)
    print(f"  SENARYO B: YENI OYUN PLANLAMA - KARAR DESTEK RAPORU")
    print("=" * 80)
    
    p = rapor['profil']
    print(f"\n[YENI OYUN PROFILI]")
    print(f"   Genre:               {p['genre']}")
    print(f"   Hedef Fiyat:         ${p['fiyat']:.2f}")
    print(f"   Hedef Wishlist:      {p.get('tahmin_wishlist', 'N/A'):,}" if p.get('tahmin_wishlist') else f"   Hedef Wishlist:      N/A")
    print(f"   Hedef Review:        {p.get('tahmin_review', 'N/A')}/100" if p.get('tahmin_review') else f"   Hedef Review:        N/A")
    
    print(f"\n[REKABET ANALIZI]")
    print(f"   Genre Pazar Pay:     {rapor['genre_pazar_pay']:.1f}% ({rapor['genre_oyun_sayisi']:,} oyun)")
    print(f"   Rekabet Seviyesi:    {rapor['rekabet_seviyesi']}")
    print(f"   Yorum:               {rapor['rekabet_aciklama']}")
    
    if rapor['wishlist_oran'] is not None:
        print(f"   Wishlist Hedef:      Bu genre'in en ust %{rapor['wishlist_oran']:.1f}'ine girer")
        print(f"   Yorum:               {rapor['wishlist_yorum']}")
    
    print(f"\n[EN BENZER 5 OYUN] (Mevcut pazardan)")
    for i, b in enumerate(rapor['benzer_oyunlar'], 1):
        rev_str = f"${b['Revenue']/1e6:.1f}M" if b['Revenue'] >= 1e6 else f"${b['Revenue']:,.0f}"
        print(f"   {i}. {str(b['Ad'])[:38]:<38} | ${b['Fiyat']:>5.2f} | WL: {b['Wishlist']:>8,.0f} | {rev_str}")
    print(f"   -> Ortalama revenue: ${rapor['benzer_ort_revenue']:,.0f}")
    print(f"   -> Ortalama review:  {rapor['benzer_ort_review']:.1f}/100")
    
    print(f"\n[SEGMENT TAHMINI]")
    print(f"   Genre 2025-2027 buyume:  {rapor['genre_buyume']*100:+.1f}%")
    print(f"   En iyi algoritma:        {rapor['genre_algo']}")
    print(f"   MAPE:                    {rapor['genre_mape']:.1f}%")
    
    print(f"\n[2027 REVENUE TAHMINI - 3 SENARYO]")
    print(f"   Best Case:    ${rapor['2027_best']:,.0f}")
    print(f"   Base Case:    ${rapor['2027_base']:,.0f}  *** ana tahmin")
    print(f"   Worst Case:   ${rapor['2027_worst']:,.0f}")
    
    print(f"\n[RISK DEGERLENDIRMESI]")
    print(f"   Risk Seviyesi: {rapor['risk_seviyesi']}")
    print("=" * 80)


