# KUME SAYISI KARSILASTIRMASI: k=3 vs k=4 vs k=10
# ════════════════════════════════════════════════════════════════════
# Bu hucrenin amaci:
#   1. Uc farkli k degeri icin KMeans calistir
#   2. Her birinin cluster dagilimini, revenue payini analiz et
#   3. Is acisindan hangisinin anlamli oldugunu degerlendir
# ════════════════════════════════════════════════════════════════════

print("=" * 75)
print("KUME SAYISI KARSILASTIRMASI: k=3, k=4, k=10")
print("=" * 75)

test_k_degerleri = [3, 4, 10]
karsilastirma_sonuclari = {}

for k in test_k_degerleri:
    # KMeans calistir
    km = KMeans(n_clusters=k, n_init=10, random_state=RANDOM_SEED)
    labels = km.fit_predict(X_kume_scaled)
    
    # Gecici dataframe
    gecici = df_clean[['Name', 'Revenue']].copy()
    gecici['cluster'] = labels
    
    # Cluster bazli ozet
    ozet = gecici.groupby('cluster').agg(
        oyun_sayisi=('Name', 'count'),
        toplam_revenue=('Revenue', 'sum'),
        ort_revenue=('Revenue', 'mean'),
        medyan_revenue=('Revenue', 'median')
    ).sort_values('toplam_revenue', ascending=False)
    
    toplam_pazar = ozet['toplam_revenue'].sum()
    ozet['pazar_pay'] = (ozet['toplam_revenue'] / toplam_pazar) * 100
    ozet['oyun_pay'] = (ozet['oyun_sayisi'] / len(gecici)) * 100
    
    karsilastirma_sonuclari[k] = ozet
    
    # Yazdir
    print(f"\n{'='*75}")
    print(f"  k = {k}")
    print(f"{'='*75}")
    print(f"\n{'Cluster':>8} {'Oyun':>10} {'Oyun%':>8} {'Toplam Rev':>15} {'Pazar%':>8} {'Ort Rev':>12}")
    print("-" * 70)
    for cluster_id, row in ozet.iterrows():
        print(f"{cluster_id:>8} {row['oyun_sayisi']:>10,.0f} "
              f"{row['oyun_pay']:>7.1f}% ${row['toplam_revenue']/1e9:>12.2f}B "
              f"{row['pazar_pay']:>7.1f}% ${row['ort_revenue']/1e3:>9.0f}K")
    
    # En dominant cluster (Pareto gostergesi)
    en_buyuk = ozet.iloc[0]
    print(f"\n  En dominant cluster: {en_buyuk['oyun_pay']:.1f}% oyun -> "
          f"{en_buyuk['pazar_pay']:.1f}% pazar payi")
    print(f"  Pareto sertligi: {en_buyuk['pazar_pay']/en_buyuk['oyun_pay']:.1f}x")

# ── Pareto Karsilastirma Tablosu ──
print(f"\n\n{'='*75}")
print("PARETO ANALIZI - HANGI k DAHA IYI AYRISTIRIYOR?")
print(f"{'='*75}")

print(f"\n{'k':>4} {'En Dom. Oyun%':>15} {'En Dom. Pazar%':>16} {'Pareto Carpani':>16}")
print("-" * 55)
for k in test_k_degerleri:
    ozet = karsilastirma_sonuclari[k]
    en_buyuk = ozet.iloc[0]
    pareto_carpani = en_buyuk['pazar_pay'] / en_buyuk['oyun_pay']
    print(f"{k:>4} {en_buyuk['oyun_pay']:>14.1f}% {en_buyuk['pazar_pay']:>15.1f}% "
          f"{pareto_carpani:>14.1f}x")

# ── Gorselleştirme ──
fig, axes = plt.subplots(1, 3, figsize=(20, 6))

for idx, k in enumerate(test_k_degerleri):
    ozet = karsilastirma_sonuclari[k].sort_index()
    
    ax = axes[idx]
    x = range(len(ozet))
    
    # Oyun sayisi (bar) ve pazar payi (cizgi)
    ax2 = ax.twinx()
    
    bars = ax.bar(x, ozet['oyun_pay'], alpha=0.6, color='#3498db', 
                  label='Oyun %')
    line = ax2.plot(x, ozet['pazar_pay'], marker='o', color='#e74c3c', 
                    linewidth=2, markersize=8, label='Pazar %')
    
    ax.set_title(f'k = {k}', fontweight='bold', fontsize=13)
    ax.set_xlabel('Cluster')
    ax.set_ylabel('Oyun Payi (%)', color='#3498db')
    ax2.set_ylabel('Pazar Payi (%)', color='#e74c3c')
    ax.set_xticks(list(x))
    ax.set_xticklabels([f'C{i}' for i in ozet.index], rotation=0)
    ax.grid(alpha=0.3)

plt.suptitle('Kume Sayisina Gore Oyun vs Pazar Payi Dagilimi', 
