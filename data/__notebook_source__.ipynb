all_results = []
atlanan_segmentler = []  # Hangileri filtrelendi, neden?

# Anlamsiz segment esikleri
ESIK_MAX = 0.01      # Train'de max < $10M → atla
ESIK_TEST = 0.01     # Test ortalamasi < $10M → atla

def calistir_segment(tip, segment_adi, series):
    """Bir segment uzerinde tum algoritmalari calistir."""
    train_data = series[:len(train_yillar)]
    test_data = series[len(train_yillar):len(train_yillar)+len(test_yillar)]
    
    # ── Iki kademeli anlamsizlik filtresi ──
    if train_data.max() < ESIK_MAX:
        atlanan_segmentler.append({
            'Tip': tip, 'Segment': segment_adi,
            'Sebep': f'Train max < ${ESIK_MAX*1000:.0f}M (bos segment)',
            'Train_max': train_data.max(),
            'Test_mean': test_data.mean()
        })
        return
    
    if test_data.mean() < ESIK_TEST:
        atlanan_segmentler.append({
            'Tip': tip, 'Segment': segment_adi,
            'Sebep': f'Test ortalama < ${ESIK_TEST*1000:.0f}M (MAPE patlar)',
            'Train_max': train_data.max(),
            'Test_mean': test_data.mean()
        })
        return
    
    print(f"\n  {segment_adi} (Train max: ${train_data.max():.2f}B, "
          f"Test ort: ${test_data.mean():.2f}B)")
    
    for algo_adi, algo_fn in algoritmalar.items():
        try:
            test_pred, forecast_pred = algo_fn(
                train_data, train_yillar, test_yillar, forecast_yillar
            )
            
            # Revenue >= 0 kisiti
            test_pred, forecast_pred = clip_negatif(test_pred, forecast_pred)
            
            mape, rmse, mae = hesapla_metrikler(test_data, test_pred)
            
            all_results.append({
                'Tip': tip,
                'Segment': segment_adi,
                'Algoritma': algo_adi,
                'MAPE': mape,
                'RMSE': rmse,
                'MAE': mae,
                'Test_2024': test_pred[0],
                'Test_2025': test_pred[1],
                'Gercek_2024': test_data[0],
                'Gercek_2025': test_data[1],
                'Forecast_2026': forecast_pred[0],
                'Forecast_2027': forecast_pred[1]
            })
            
            mape_str = f"{mape:>6.1f}%" if pd.notna(mape) else "    nan"
            print(f"    {algo_adi:<12} MAPE={mape_str}  "
                  f"RMSE={rmse:.3f} | 2027: ${forecast_pred[1]:.2f}B")
        except Exception as e:
            print(f"    {algo_adi:<12} HATA: {str(e)[:60]}")


