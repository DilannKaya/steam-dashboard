print(f"  Max:    {df_clean['Average playtime'].max():,.0f}")

# ── DUZELTME 1: $ Price cent -> dolar ──────────────────────────────
df_clean['price_usd'] = df_clean['$ Price'] / 100

# ── DUZELTME 2: Average playtime log donusumu ──────────────────────
# log1p kullanildi: log(1+x) -> sifirlar icin guvenli
df_clean['log_playtime'] = np.log1p(df_clean['Average playtime'].fillna(0))

# ── Sonuclari goster ──────────────────────────────────────────────
print(f"\n>>> DUZELTMENIN SONRASI:")
print(f"price_usd istatistikleri:")
