def lewis_kategorisi(mape):
    """Lewis (1982) MAPE esiklerine gore guven sinifi."""
    if mape < 10:
        return 'Yuksek', 'Guvenle yatirim karari'
    elif mape < 20:
        return 'Orta', 'Yatirim + risk uyarisi'
    elif mape < 50:
        return 'Dusuk', 'Alternatif degerlendirme onerilir'
    else:
        return 'Cok dusuk', 'Karar destek icin kullanilamaz'


def gercek_oyun_sec(cluster_id, anlamli_genres, df):
    """
    Bir cluster'dan AKILLI sekilde temsili bir oyun sec.
    
    Filtreler:
    1. Cluster eslesmeli
    2. log_revenue > 0 (gercek revenue olmali)
    3. primary_genre anlamli listede
    4. Oyun adinda excluded kelimeler olmamali (mod/server/DLC)
    """
    mask_cluster = df['kmeans_cluster'] == cluster_id
    
    if 'log_revenue' in df.columns:
        mask_revenue = df['log_revenue'] > 0
    else:
        mask_revenue = pd.Series([True] * len(df), index=df.index)
    
    if 'primary_genre' in df.columns:
        mask_genre = df['primary_genre'].isin(anlamli_genres)
    else:
        mask_genre = pd.Series([True] * len(df), index=df.index)
    
    excluded = ['Mod Tools', 'Dedicated Server', 'Editor', 'DLC',
                'Soundtrack', 'OST', 'Music Pack', 'Demo', 'Beta',
                'Test Build', 'SDK', 'Driver', 'Asset', 'Trial',
                'Server', 'Workshop', 'Pack -', 'Volume',
                'Free Trial', 'Free Demo']
    
    name_col = None
    for c in ['Name', 'name', 'title', 'Title']:
        if c in df.columns:
            name_col = c
            break
    
    if name_col is not None:
        pattern = '|'.join(excluded)
        mask_name = ~df[name_col].astype(str).str.contains(pattern, case=False, na=False)
    else:
        mask_name = pd.Series([True] * len(df), index=df.index)
    
    aday = df[mask_cluster & mask_revenue & mask_genre & mask_name]
    
    if len(aday) == 0:
        aday = df[mask_cluster & mask_revenue & mask_name]
        if len(aday) == 0:
            return None
    
    return int(aday.nlargest(1, 'log_revenue').index[0])


def content_based_tahmin(oyun_index_global, K=5):
    """Tek bir oyun icin Content-Based log_revenue tahmini (self-exclusion ile)."""
    from sklearn.metrics.pairwise import cosine_similarity
    
    if oyun_index_global in train_idx:
        local_idx = np.where(train_idx == oyun_index_global)[0][0]
        oyun_content = X_content_train[local_idx:local_idx+1]
        is_train = True
    else:
        local_idx = np.where(test_idx == oyun_index_global)[0][0]
        oyun_content = X_content_test[local_idx:local_idx+1]
        is_train = False
    
    similarities = cosine_similarity(oyun_content, X_content_train)[0]
    
    if is_train:
        top_k_idx = np.argsort(-similarities)[1:K+1]
    else:
        top_k_idx = np.argsort(-similarities)[:K]
    
    return float(y_train[top_k_idx].mean())


