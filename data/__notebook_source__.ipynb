print(f"En az 1000 oyunu olan genre: {(genre_df['Oyun_Sayisi'] >= 1000).sum()}")
print(f"En az 10000 oyunu olan genre: {(genre_df['Oyun_Sayisi'] >= 10000).sum()}")

